---
// 中文: 全站基础布局，集中加载全局样式、页眉页脚、SEO 元信息和缓存策略。
// EN: Base site layout that loads global styles, header/footer, SEO metadata, and cache policy hints.
import "../styles/global.css";
import Header from "../components/site/Header.astro";
import Footer from "../components/site/Footer.astro";

type Props = {
  title?: string;
  description?: string;
  lang?: string;
  bodyClass?: string;
};

const {
  title = "RainyMatinal 苦难摇篮",
  description = "RainyMatinal 的个人技术摇篮。",
  lang = "zh-CN",
  bodyClass = "",
} = Astro.props;

const siteName = "RainyMatinal 苦难摇篮";
const pageTitle = title === siteName ? title : `${title} • ${siteName}`;
const isHome = Astro.url.pathname === "/";
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#EFEBE0" />
    <meta name="generator" content={Astro.generator} />
    <meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate" />
    <meta http-equiv="Pragma" content="no-cache" />
    <meta http-equiv="Expires" content="0" />
    <meta name="rainy-signature-animation-version" content="rainy-signature-v20260701-6" />
    <meta name="astro-view-transitions-enabled" content="true" />
    <meta name="astro-view-transitions-fallback" content="animate" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Lexend:wght@300..900&family=Noto+Sans+SC:wght@400..900&family=Noto+Serif+SC:wght@400..900&family=Noto+Serif:ital,wght@0,400..900;1,400..900&display=swap" rel="stylesheet" media="print" onload="this.media='all'" />
    <link href="https://fonts.googleapis.com/css2?family=Niconne&display=swap&text=RainyMatinal" rel="stylesheet" media="print" onload="this.media='all'" />
    <title>{pageTitle}</title>
  </head>
  <body class={bodyClass}>
    <a class="skip-link" href="#content">跳到正文</a>
    <div class="site-shell">
      <Header isHome={isHome} />
      <main class="site-main" id="content">
        <slot />
      </main>
      <Footer />
    </div>
  </body>
</html>