<footer class="footer">
  <div class="site-shell footer-inner">
    <p class="ui-font">© {new Date().getFullYear()} 生活与设计笔记</p>
    <div class="footer-links">
      <a href="/rss.xml" aria-label="RSS">
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 5c7.7 0 14 6.3 14 14M5 11c4.4 0 8 3.6 8 8" /><circle cx="6" cy="18" r="1" /></svg>
      </a>
      <a href="mailto:hello@example.com" aria-label="Email">
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 6h16v12H4z" /><path d="m4 7 8 6 8-6" /></svg>
      </a>
    </div>
  </div>
</footer>

<style>
  .footer {
    margin-top: 96px;
    border-top: var(--border-doodle);
    background: var(--color-surface);
    box-shadow: 0 -5px 0 var(--color-shadow);
  }

  .footer-inner {
    display: flex;
    min-height: 104px;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    color: var(--color-text);
    font-size: 18px;
    font-weight: 700;
  }

  .footer-links {
    display: flex;
    gap: 14px;
  }

  .footer-links a {
    display: grid;
    width: 42px;
    height: 42px;
    place-items: center;
    border: 2px solid var(--color-border);
    border-radius: 16px 10px 18px 12px / 10px 16px 12px 18px;
    background: var(--color-surface-strong);
    box-shadow: var(--shadow-doodle-small);
    color: #171411;
  }

  .footer-links a:hover {
    background: var(--color-accent);
    box-shadow: 2px 2px 0 var(--color-shadow);
    color: #fffdf3;
    transform: translate(2px, 2px) rotate(-4deg);
  }

  .footer-links svg {
    width: 16px;
    height: 16px;
    fill: none;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 1.8;
  }
</style>
