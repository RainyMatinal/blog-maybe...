---
import type { Lang } from '@/i18n/ui';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const rssHref = lang === 'zh' ? '/rss.xml' : '/en/rss.xml';
---

<footer class="footer">
  <div class="site-shell footer-inner">
    <p class="ui-font">© {new Date().getFullYear()} {lang === 'zh' ? '生活与设计笔记' : 'Life & Design Notes'}</p>
    <div class="footer-links">
      <a href={rssHref} aria-label="RSS">
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 5c7.7 0 14 6.3 14 14M5 11c4.4 0 8 3.6 8 8" /><circle cx="6" cy="18" r="1" /></svg>
      </a>
      <a href="mailto:hello@example.com" aria-label="Email">
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 6h16v12H4z" /><path d="m4 7 8 6 8-6" /></svg>
      </a>
    </div>
  </div>
</footer>

<style>
  .footer {
    margin-top: 96px;
    border-top: 1px solid var(--color-border);
  }

  .footer-inner {
    display: flex;
    min-height: 104px;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    color: var(--color-muted);
    font-size: 13px;
  }

  .footer-links {
    display: flex;
    gap: 14px;
  }

  .footer-links a {
    display: grid;
    width: 34px;
    height: 34px;
    place-items: center;
    border: 1px solid var(--color-border);
  }

  .footer-links svg {
    width: 16px;
    height: 16px;
    fill: none;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 1.8;
  }
</style>
