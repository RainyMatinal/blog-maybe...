---
interface Props {
  href?: string;
  title?: string;
  description?: string;
}

const {
  href = 'https://music.163.com/',
  title = '网易云音乐',
  description = '把常听的歌单接到这里。'
} = Astro.props;
---

<aside class="music-widget" aria-label="网易云音乐组件">
  <div class="record" aria-hidden="true">
    <span></span>
  </div>
  <div class="music-copy">
    <p class="music-kicker">Now playing</p>
    <h2>{title}</h2>
    <p>{description}</p>
  </div>
  <a class="ui-font music-link" href={href} target="_blank" rel="noreferrer">打开网易云</a>
</aside>

<style>
  .music-widget {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    gap: 18px;
    align-items: center;
    margin-top: 34px;
    padding: 18px;
    border: 1px solid color-mix(in srgb, var(--color-border) 18%, transparent);
    border-radius: 28px;
    background:
      linear-gradient(135deg, rgba(255, 253, 243, 0.92), rgba(255, 240, 168, 0.5)),
      var(--color-surface);
    box-shadow: 0 16px 50px rgba(23, 20, 17, 0.1);
  }

  .record {
    display: grid;
    width: 78px;
    height: 78px;
    place-items: center;
    border: 2px solid var(--color-border);
    border-radius: 50%;
    background:
      radial-gradient(circle, var(--color-surface-strong) 0 9px, var(--color-border) 10px 12px, transparent 13px),
      repeating-radial-gradient(circle, var(--color-border) 0 2px, #2a2520 3px 7px);
    box-shadow: 4px 4px 0 var(--color-shadow);
    animation: record-spin 9s linear infinite;
  }

  .record span {
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: var(--color-surface);
  }

  .music-copy {
    min-width: 0;
  }

  .music-kicker {
    margin: 0 0 4px;
    color: var(--color-accent);
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .music-copy h2 {
    margin: 0;
    color: var(--color-text);
    font-family: 'Noto Serif SC', serif;
    font-size: clamp(22px, 4vw, 32px);
    line-height: 1.25;
  }

  .music-copy p:last-child {
    margin: 4px 0 0;
    color: var(--color-muted);
    font-size: 15px;
    line-height: 1.7;
  }

  .music-link {
    padding: 5px 12px;
    border: 2px solid var(--color-border);
    border-radius: 18px 12px 20px 13px / 12px 18px 10px 16px;
    background: var(--color-surface-strong);
    box-shadow: var(--shadow-doodle-small);
    color: var(--color-text);
    font-size: 17px;
    font-weight: 700;
    white-space: nowrap;
  }

  .music-link:hover {
    background: var(--color-accent);
    box-shadow: 1px 1px 0 var(--color-shadow);
    color: var(--color-surface);
    transform: translate(2px, 2px) rotate(-2deg);
  }

  @keyframes record-spin {
    to {
      transform: rotate(360deg);
    }
  }

  @media (max-width: 720px) {
    .music-widget {
      grid-template-columns: auto 1fr;
    }

    .music-link {
      grid-column: 1 / -1;
      width: fit-content;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .record {
      animation: none;
    }
  }
</style>
