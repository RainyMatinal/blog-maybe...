---
interface Props {
  tag: string;
  active?: boolean;
  asButton?: boolean;
}

const { tag, active = false, asButton = false } = Astro.props;
---

{asButton ? (
  <button class:list={['ui-font', 'tag-pill', { active }]} type="button" data-tag-filter={tag}>{tag}</button>
) : (
  <span class:list={['ui-font', 'tag-pill', { active }]}>{tag}</span>
)}

<style>
  .tag-pill {
    display: inline-flex;
    align-items: center;
    min-height: 28px;
    padding: 0 10px;
    border: 1px solid var(--color-border);
    background: var(--color-accent-bg);
    color: var(--color-accent);
    font-size: 12px;
    line-height: 1;
    letter-spacing: 0.03em;
    white-space: nowrap;
  }

  button.tag-pill {
    cursor: pointer;
  }

  .tag-pill.active,
  button.tag-pill:hover {
    border-color: var(--color-accent);
    background: var(--color-accent);
    color: var(--color-bg);
  }
</style>
