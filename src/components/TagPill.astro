---
interface Props {
  tag: string;
  active?: boolean;
  asButton?: boolean;
}

const { tag, active = false, asButton = false } = Astro.props;
---

{asButton ? (
  <button class:list={['ui-font', 'tag-pill', { active }]} type="button" data-tag-filter={tag}>{tag}</button>
) : (
  <span class:list={['ui-font', 'tag-pill', { active }]}>{tag}</span>
)}

<style>
  .tag-pill {
    display: inline-flex;
    align-items: center;
    min-height: 28px;
    padding: 0 10px;
    border: 2px solid var(--color-border);
    border-radius: 18px 13px 20px 12px / 12px 18px 10px 16px;
    background: var(--color-accent-bg);
    box-shadow: 3px 3px 0 var(--color-shadow);
    color: var(--color-text);
    font-size: 15px;
    font-weight: 700;
    line-height: 1;
    white-space: nowrap;
    transform: rotate(-1deg);
  }

  button.tag-pill {
    cursor: pointer;
  }

  .tag-pill.active,
  button.tag-pill:hover {
    border-color: var(--color-accent);
    background: var(--color-accent);
    box-shadow: 1px 1px 0 var(--color-shadow);
    color: #fffdf3;
    transform: translate(2px, 2px) rotate(2deg);
  }
</style>
