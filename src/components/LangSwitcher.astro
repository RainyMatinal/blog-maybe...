---
import type { Lang } from '@/i18n/ui';
import { localizedPath, otherLang, useTranslations } from '@/i18n/utils';

interface Props {
  lang: Lang;
  to?: string;
}

const { lang, to } = Astro.props;
const t = useTranslations(lang);
const targetLang = otherLang(lang);
const href = to ?? localizedPath(targetLang, '/');
---

<a class="ui-font lang-switch" href={href} aria-label={lang === 'zh' ? 'Switch to English' : '切换到中文'}>
  {t('lang.switch')}
</a>

<style>
  .lang-switch {
    display: inline-flex;
    min-width: 44px;
    min-height: 36px;
    align-items: center;
    justify-content: center;
    border: 2px solid var(--color-border);
    border-radius: 18px 12px 20px 13px / 12px 18px 10px 16px;
    background: var(--color-surface);
    box-shadow: var(--shadow-doodle-small);
    color: var(--color-text);
    font-size: 17px;
    font-weight: 700;
  }

  .lang-switch:hover {
    background: var(--color-accent-2);
    box-shadow: 2px 2px 0 var(--color-shadow);
    color: #fffdf3;
    transform: translate(2px, 2px) rotate(2deg);
  }

</style>
