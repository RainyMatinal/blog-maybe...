---
import type { Lang } from '@/i18n/ui';
import { localizedPath, otherLang, useTranslations } from '@/i18n/utils';

interface Props {
  lang: Lang;
  to?: string;
}

const { lang, to } = Astro.props;
const t = useTranslations(lang);
const targetLang = otherLang(lang);
const href = to ?? localizedPath(targetLang, '/');
---

<a class="ui-font lang-switch" href={href} aria-label={lang === 'zh' ? 'Switch to English' : '切换到中文'}>
  {t('lang.switch')}
</a>

<style>
  .lang-switch {
    display: inline-flex;
    min-width: 44px;
    min-height: 36px;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--color-border);
    color: var(--color-muted);
    font-size: 13px;
    letter-spacing: 0.04em;
  }

  .lang-switch:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }
</style>
