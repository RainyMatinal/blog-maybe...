---
import { Image } from 'astro:assets';
import { ledgerEntries } from '@/content/ledger';

const formatter = new Intl.DateTimeFormat('zh-CN', {
  year: 'numeric',
  month: '2-digit',
  day: '2-digit',
  hour: '2-digit',
  minute: '2-digit',
  hour12: false,
  timeZone: 'Asia/Hong_Kong'
});

const entries = [...ledgerEntries].sort(
  (a, b) => new Date(b.publishedAt).getTime() - new Date(a.publishedAt).getTime()
);
---

<section class="site-shell ledger-section" aria-labelledby="ledger-title">
  <div class="ledger-cover" aria-hidden="true">
    <div class="ledger-cover-copy">
      <span>Rainy Note Archive</span>
      <strong>{entries.length}</strong>
    </div>
    <Image src="/images/blog-departure-chalk.svg" alt="" width={900} height={620} loading="lazy" />
  </div>

  <div class="ledger-head">
    <p class="ledger-kicker">Source-only notes</p>
    <h2 id="ledger-title">全部手账</h2>
    <p>内容按源文件时间倒序排列。网页只负责阅读，不提供新增、编辑和删除入口。</p>
  </div>

  <div class="ledger-list">
    {entries.map((entry, index) => (
      <article class="ledger-row" id={entry.id}>
        <a class="ledger-anchor" href={`#${entry.id}`} aria-label={`定位到 ${entry.title ?? '手账'}`}>
          #{String(index + 1).padStart(2, '0')}
        </a>
        <div class="ledger-body">
          <time datetime={entry.publishedAt}>{formatter.format(new Date(entry.publishedAt))}</time>
          {entry.title && <h3>{entry.title}</h3>}
          <p>{entry.body}</p>
        </div>
      </article>
    ))}
  </div>

</section>

<style>
  .ledger-section {
    position: relative;
    margin-top: clamp(56px, 9vw, 112px);
    padding-bottom: 24px;
  }

  .ledger-cover {
    position: relative;
    display: grid;
    min-height: clamp(260px, 44vw, 460px);
    overflow: hidden;
    border: 1px solid color-mix(in srgb, var(--color-border) 18%, transparent);
    border-radius: 28px;
    background:
      linear-gradient(180deg, rgba(255, 253, 243, 0.42), rgba(255, 248, 223, 0.92)),
      var(--color-surface);
    box-shadow: 0 18px 60px rgba(23, 20, 17, 0.12);
  }

  .ledger-cover::after {
    position: absolute;
    inset: 18px;
    border: 1px solid rgba(23, 20, 17, 0.12);
    border-radius: 22px;
    content: '';
    pointer-events: none;
  }

  .ledger-cover :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: saturate(0.96) contrast(0.98);
    opacity: 0.72;
  }

  .ledger-cover-copy {
    position: absolute;
    left: clamp(18px, 4vw, 44px);
    bottom: clamp(18px, 4vw, 44px);
    z-index: 1;
    display: grid;
    gap: 8px;
    padding: 16px 18px;
    border: 1px solid rgba(23, 20, 17, 0.14);
    border-radius: 20px;
    background: rgba(255, 253, 243, 0.78);
    backdrop-filter: blur(10px);
  }

  .ledger-cover-copy span {
    color: var(--color-muted);
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .ledger-cover-copy strong {
    color: var(--color-text);
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(54px, 9vw, 98px);
    font-style: italic;
    font-weight: 400;
    line-height: 0.8;
  }

  .ledger-head {
    display: grid;
    gap: 10px;
    max-width: 760px;
    margin: clamp(28px, 5vw, 54px) auto 28px;
    text-align: center;
  }

  .ledger-kicker {
    margin: 0;
    color: var(--color-accent);
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    font-weight: 400;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .ledger-head h2 {
    margin: 0;
    color: var(--color-text);
    font-family: 'Noto Serif SC', serif;
    font-size: clamp(36px, 7vw, 68px);
    font-weight: 700;
    letter-spacing: 0.02em;
    line-height: 1.15;
  }

  .ledger-head p {
    margin: 0;
    color: var(--color-muted);
    font-size: clamp(16px, 2.5vw, 19px);
    line-height: 1.9;
  }

  .ledger-list {
    display: grid;
    gap: 0;
    overflow: hidden;
    border: 1px solid color-mix(in srgb, var(--color-border) 16%, transparent);
    border-radius: 26px;
    background: color-mix(in srgb, var(--color-surface) 92%, transparent);
    box-shadow: 0 16px 48px rgba(23, 20, 17, 0.08);
  }

  .ledger-row {
    display: grid;
    grid-template-columns: 96px minmax(0, 1fr);
    gap: clamp(16px, 4vw, 34px);
    padding: clamp(18px, 4vw, 34px);
    border-bottom: 1px solid color-mix(in srgb, var(--color-border) 12%, transparent);
    background:
      linear-gradient(90deg, rgba(255, 240, 168, 0.18), transparent 32%),
      rgba(255, 253, 243, 0.72);
  }

  .ledger-row:last-child {
    border-bottom: 0;
  }

  .ledger-row:hover {
    background:
      linear-gradient(90deg, rgba(255, 240, 168, 0.3), transparent 36%),
      rgba(255, 253, 243, 0.94);
  }

  .ledger-anchor {
    color: var(--color-muted);
    font-family: 'JetBrains Mono', monospace;
    font-size: 13px;
    letter-spacing: 0.08em;
  }

  .ledger-anchor:hover {
    color: var(--color-accent);
  }

  .ledger-body time {
    display: inline-block;
    margin-bottom: 8px;
    color: var(--color-muted);
    font-family: 'JetBrains Mono', monospace;
    font-size: 13px;
    letter-spacing: 0.08em;
  }

  .ledger-body h3 {
    margin: 0 0 8px;
    color: var(--color-text);
    font-family: 'Noto Serif SC', serif;
    font-size: clamp(22px, 4vw, 30px);
    font-weight: 700;
    line-height: 1.35;
  }

  .ledger-body p {
    margin: 0;
    color: var(--color-text);
    font-size: clamp(16px, 2.4vw, 19px);
    line-height: 2;
    white-space: pre-line;
    overflow-wrap: anywhere;
  }

  @media (max-width: 720px) {
    .ledger-cover {
      min-height: 240px;
    }

    .ledger-row {
      grid-template-columns: 1fr;
      gap: 8px;
    }

  }
</style>
