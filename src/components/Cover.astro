---
import { Image } from 'astro:assets';

interface Props {
  src: string;
  alt: string;
  eager?: boolean;
}

const { src, alt, eager = false } = Astro.props;
const isSvg = src.endsWith('.svg');
const imageProps = {
  src,
  alt,
  width: 1200,
  height: 800,
  loading: eager ? 'eager' : 'lazy',
  decoding: 'async',
  ...(isSvg ? {} : { format: 'webp' })
} as const;
---

<figure class="cover">
  <Image {...imageProps} />
</figure>

<style>
  .cover {
    position: relative;
    margin: 0;
    overflow: hidden;
    border: var(--border-doodle);
    border-radius: 28px 16px 34px 18px / 18px 32px 15px 26px;
    background: var(--color-surface);
    box-shadow: var(--shadow-doodle-small);
    aspect-ratio: 3 / 2;
  }

  .cover::after {
    position: absolute;
    inset: 10px;
    border: 2px dashed color-mix(in srgb, var(--color-border) 70%, transparent);
    border-radius: 24px 14px 28px 16px / 16px 26px 14px 22px;
    content: '';
    pointer-events: none;
  }

  .cover :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: saturate(1.25) contrast(1.06);
    transition: filter 220ms ease, transform 220ms ease;
  }

  .cover:hover :global(img) {
    filter: saturate(1.45) contrast(1.12);
    transform: scale(1.03) rotate(-1deg);
  }
</style>
