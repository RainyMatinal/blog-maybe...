<section class="letter-signature-area" aria-label="Rainy signature" data-article-signature>
  <div class="signature-svg-wrapper">
    <svg
      class="rainy-signature-svg"
      width="100%"
      height="100%"
      viewBox="0 0 500 170"
      version="1.1"
      xmlns="http://www.w3.org/2000/svg"
      aria-hidden="true"
    >
      <path
        pathLength="1"
        class="signature-path path-1"
        d="M35 138C46 96 54 55 61 22"
      />
      <path
        pathLength="1"
        class="signature-path path-2"
        d="M61 22C120 12 143 45 120 74C101 98 68 98 49 88C84 94 120 116 139 145"
      />
      <path
        pathLength="1"
        class="signature-path path-3"
        d="M170 92C150 92 136 111 141 126C148 147 180 137 190 105C183 130 184 146 198 139C207 134 216 120 222 108"
      />
      <path
        pathLength="1"
        class="signature-path path-4"
        d="M244 91C233 119 227 145 241 139C255 133 267 104 274 89M278 62C282 56 289 57 291 63"
      />
      <path
        pathLength="1"
        class="signature-path path-5"
        d="M306 140C317 101 327 84 337 90C349 98 329 132 341 138C354 144 378 103 388 90"
      />
      <path
        pathLength="1"
        class="signature-path path-6"
        d="M410 91C397 123 399 144 414 136C429 128 443 101 452 88C438 132 424 154 402 160C383 165 375 154 389 144C411 128 449 123 482 101"
      />
    </svg>
  </div>
  <div class="signature-slogan">
    <p class="slogan-primary">「雨が美しく描かれているから」</p>
    <p class="slogan-sub">近代的自我が揺れる青春の雨</p>
  </div>
</section>

<script>
  const signatures = document.querySelectorAll<HTMLElement>('[data-article-signature]');
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)');

  signatures.forEach((signature) => {
    if (reduceMotion.matches) {
      signature.classList.add('has-drawn');
      return;
    }

    let intervalId: number | undefined;

    const play = () => {
      signature.classList.remove('is-drawing');
      void signature.offsetWidth;
      signature.classList.add('is-drawing');
    };

    const stop = () => {
      if (intervalId) window.clearInterval(intervalId);
      intervalId = undefined;
      signature.classList.remove('is-drawing');
    };

    const observer = new IntersectionObserver(
      ([entry]) => {
        if (entry.isIntersecting) {
          play();
          if (!intervalId) intervalId = window.setInterval(play, 5000);
        } else {
          stop();
        }
      },
      { threshold: 0.35 }
    );

    observer.observe(signature);
  });
</script>

<style>
  .letter-signature-area {
    display: grid;
    gap: 8px;
    width: min(100% - 32px, 560px);
    margin: clamp(44px, 7vw, 72px) auto 0;
    color: #171411;
  }

  .signature-svg-wrapper {
    width: min(100%, 360px);
    height: auto;
    aspect-ratio: 500 / 170;
    margin-inline: auto;
  }

  .rainy-signature-svg {
    display: block;
    overflow: visible;
  }

  .signature-path {
    fill: none;
    stroke: currentColor;
    stroke-width: 4px;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-miterlimit: 1.5;
    stroke-dasharray: 1;
    stroke-dashoffset: 1;
  }

  .is-drawing .path-1 {
    animation: signature-draw 0.75s ease forwards;
  }

  .is-drawing .path-2 {
    animation: signature-draw 0.95s ease 0.45s forwards;
  }

  .is-drawing .path-3 {
    animation: signature-draw 0.72s ease 1.15s forwards;
  }

  .is-drawing .path-4 {
    animation: signature-draw 0.68s ease 1.62s forwards;
  }

  .is-drawing .path-5 {
    animation: signature-draw 0.74s ease 2.02s forwards;
  }

  .is-drawing .path-6 {
    animation: signature-draw 0.9s ease 2.48s forwards;
  }

  .has-drawn .signature-path {
    stroke-dashoffset: 0;
  }

  .signature-slogan {
    display: grid;
    gap: 1px;
    justify-items: end;
    color: var(--color-muted);
    font-size: clamp(11px, 1.7vw, 14px);
    line-height: 1.65;
    text-align: right;
  }

  .signature-slogan p {
    margin: 0;
  }

  .slogan-primary {
    color: var(--color-text);
  }

  @keyframes signature-draw {
    to {
      stroke-dashoffset: 0;
    }
  }

  @media (max-width: 640px) {
    .letter-signature-area {
      width: min(100% - 32px, 420px);
    }

    .signature-svg-wrapper {
      width: min(100%, 300px);
    }

    .signature-slogan {
      justify-items: start;
      text-align: left;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .signature-path {
      stroke-dashoffset: 0;
      animation: none !important;
    }
  }
</style>
