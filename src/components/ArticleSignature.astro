<section class="letter-signature-area" aria-label="Rainy signature" data-article-signature>
  <div class="signature-svg-wrapper">
    <svg
      class="rainy-signature-svg"
      width="100%"
      height="100%"
      viewBox="0 0 500 170"
      version="1.1"
      xmlns="http://www.w3.org/2000/svg"
      aria-hidden="true"
    >
      <path
        pathLength="1"
        class="signature-path path-1"
        d="M18 102C40 48 91 28 119 47C145 65 127 104 78 98C123 105 144 122 151 148C143 105 164 55 206 43C238 34 260 49 252 70C243 96 196 101 162 86"
      />
      <path
        pathLength="1"
        class="signature-path path-2"
        d="M252 101C274 60 307 52 318 69C331 89 299 124 276 112C306 124 338 105 356 75C337 124 339 149 357 129C371 113 386 71 399 74C416 78 386 136 401 132C416 127 444 78 454 75C467 71 447 129 462 128C473 127 487 112 494 101"
      />
      <path
        pathLength="1"
        class="signature-path path-3"
        d="M42 158C126 141 214 139 291 148C350 155 415 153 474 136"
      />
    </svg>
  </div>
  <div class="signature-slogan">
    <p class="slogan-primary">「雨が美しく描かれているから」</p>
    <p class="slogan-sub">近代的自我が揺れる青春の雨</p>
  </div>
</section>

<script>
  const signatures = document.querySelectorAll<HTMLElement>('[data-article-signature]');
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)');

  signatures.forEach((signature) => {
    if (reduceMotion.matches) {
      signature.classList.add('has-drawn');
      return;
    }

    let intervalId: number | undefined;

    const play = () => {
      signature.classList.remove('is-drawing');
      void signature.offsetWidth;
      signature.classList.add('is-drawing');
    };

    const stop = () => {
      if (intervalId) window.clearInterval(intervalId);
      intervalId = undefined;
      signature.classList.remove('is-drawing');
    };

    const observer = new IntersectionObserver(
      ([entry]) => {
        if (entry.isIntersecting) {
          play();
          if (!intervalId) intervalId = window.setInterval(play, 5000);
        } else {
          stop();
        }
      },
      { threshold: 0.35 }
    );

    observer.observe(signature);
  });
</script>

<style>
  .letter-signature-area {
    display: grid;
    gap: 8px;
    width: min(100% - 32px, 560px);
    margin: clamp(44px, 7vw, 72px) auto 0;
    color: #171411;
  }

  .signature-svg-wrapper {
    width: min(100%, 360px);
    height: auto;
    aspect-ratio: 500 / 170;
    margin-inline: auto;
  }

  .rainy-signature-svg {
    display: block;
    overflow: visible;
  }

  .signature-path {
    fill: none;
    stroke: currentColor;
    stroke-width: 4px;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-miterlimit: 1.5;
    stroke-dasharray: 1;
    stroke-dashoffset: 1;
  }

  .is-drawing .path-1 {
    animation: signature-draw 1.7s ease forwards;
  }

  .is-drawing .path-2 {
    animation: signature-draw 1.6s ease 1.15s forwards;
  }

  .is-drawing .path-3 {
    animation: signature-draw 0.9s ease 2.45s forwards;
  }

  .has-drawn .signature-path {
    stroke-dashoffset: 0;
  }

  .signature-slogan {
    display: grid;
    gap: 1px;
    justify-items: end;
    color: var(--color-muted);
    font-size: clamp(11px, 1.7vw, 14px);
    line-height: 1.65;
    text-align: right;
  }

  .signature-slogan p {
    margin: 0;
  }

  .slogan-primary {
    color: var(--color-text);
  }

  @keyframes signature-draw {
    to {
      stroke-dashoffset: 0;
    }
  }

  @media (max-width: 640px) {
    .letter-signature-area {
      width: min(100% - 32px, 420px);
    }

    .signature-svg-wrapper {
      width: min(100%, 300px);
    }

    .signature-slogan {
      justify-items: start;
      text-align: left;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .signature-path {
      stroke-dashoffset: 0;
      animation: none !important;
    }
  }
</style>
