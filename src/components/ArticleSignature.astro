<section class="letter-signature-area" aria-label="Rainy signature" data-article-signature>
  <canvas class="signature-rain-canvas" data-signature-rain aria-hidden="true"></canvas>

  <div class="signature-svg-wrapper">
    <svg
      class="rainy-signature-svg"
      width="100%"
      height="100%"
      viewBox="0 0 620 210"
      version="1.1"
      xmlns="http://www.w3.org/2000/svg"
      aria-hidden="true"
    >
      <path
        class="signature-path path-r-stem"
        data-signature-path
        d="M48 166C62 112 73 61 82 22"
      />
      <path
        class="signature-path path-r-bloom"
        data-signature-path
        d="M82 22C151 7 178 44 153 78C132 106 89 105 66 93C109 99 151 128 174 169"
      />
      <path
        class="signature-path path-a"
        data-signature-path
        d="M216 105C190 102 169 123 174 145C180 174 222 159 236 111C228 151 232 171 249 160C260 153 270 136 279 119"
      />
      <path
        class="signature-path path-i"
        data-signature-path
        d="M312 104C297 140 291 172 310 162C330 151 344 119 352 100M358 62C363 53 374 54 377 64"
      />
      <path
        class="signature-path path-n"
        data-signature-path
        d="M395 166C411 115 425 95 441 104C458 115 429 158 448 166C468 174 496 119 508 101"
      />
      <path
        class="signature-path path-y-underline"
        data-signature-path
        d="M548 102C530 145 534 173 554 162C574 151 591 116 605 98C585 163 561 194 526 199C497 203 486 183 506 166C536 140 585 137 610 117M109 188C246 168 410 174 590 151"
      />
    </svg>
  </div>

  <div class="signature-rain-lines" data-signature-rain-lines aria-hidden="true">
    <svg viewBox="0 0 96 72" xmlns="http://www.w3.org/2000/svg">
      <path d="M24 8 10 36" />
      <path d="M48 2 31 39" />
      <path d="M72 10 55 46" />
      <path d="M88 27 74 58" />
    </svg>
  </div>

  <div class="signature-slogan">
    <p class="slogan-primary">「雨が美しく描かれているから」</p>
    <p class="slogan-sub">近代的自我が揺れる青春の雨</p>
  </div>
</section>

<script>
  const SIGNATURE_TOTAL_DURATION = 2500;
  const SIGNATURE_REPLAY_INTERVAL = 5000;
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)');

  const resetPath = (path: SVGPathElement, length: number) => {
    path.style.transition = 'none';
    path.style.strokeDasharray = `${length}`;
    path.style.strokeDashoffset = `${length}`;
  };

  const drawPath = (path: SVGPathElement, duration: number, delay: number) => {
    path.style.transition = `stroke-dashoffset ${duration}ms cubic-bezier(0.16, 1, 0.3, 1) ${delay}ms`;
    path.style.strokeDashoffset = '0';
  };

  const startRainCanvas = (canvas: HTMLCanvasElement) => {
    const context = canvas.getContext('2d');
    if (!context) return () => {};

    let frameId = 0;
    let running = true;
    let width = 0;
    let height = 0;
    const drops = Array.from({ length: 34 }, () => ({
      x: Math.random(),
      y: Math.random(),
      length: 8 + Math.random() * 18,
      speed: 0.0025 + Math.random() * 0.004,
      opacity: 0.05 + Math.random() * 0.12,
    }));

    const resize = () => {
      const rect = canvas.getBoundingClientRect();
      const pixelRatio = Math.min(window.devicePixelRatio || 1, 2);
      width = Math.max(1, rect.width);
      height = Math.max(1, rect.height);
      canvas.width = Math.floor(width * pixelRatio);
      canvas.height = Math.floor(height * pixelRatio);
      context.setTransform(pixelRatio, 0, 0, pixelRatio, 0, 0);
    };

    const render = () => {
      if (!running) return;

      context.clearRect(0, 0, width, height);
      context.lineWidth = 1;
      context.lineCap = 'round';

      drops.forEach((drop) => {
        drop.y += drop.speed;
        if (drop.y > 1.12) {
          drop.y = -0.08;
          drop.x = Math.random();
        }

        const x = drop.x * width;
        const y = drop.y * height;
        context.strokeStyle = `rgba(23, 20, 17, ${drop.opacity})`;
        context.beginPath();
        context.moveTo(x, y);
        context.lineTo(x - 5, y + drop.length);
        context.stroke();
      });

      frameId = window.requestAnimationFrame(render);
    };

    resize();
    window.addEventListener('resize', resize, { passive: true });
    frameId = window.requestAnimationFrame(render);

    return () => {
      running = false;
      window.cancelAnimationFrame(frameId);
      window.removeEventListener('resize', resize);
    };
  };

  const initArticleSignatures = () => {
    const signatures = document.querySelectorAll<HTMLElement>('[data-article-signature]');

    signatures.forEach((signature) => {
      if (signature.dataset.signatureReady === 'true') return;
      signature.dataset.signatureReady = 'true';

      const paths = Array.from(signature.querySelectorAll<SVGPathElement>('[data-signature-path]'));
      const rainCanvas = signature.querySelector<HTMLCanvasElement>('[data-signature-rain]');
      const rainLines = signature.querySelector<HTMLElement>('[data-signature-rain-lines]');
      const svg = signature.querySelector<SVGSVGElement>('.rainy-signature-svg');

      if (!paths.length || !svg) return;

      const pathLengths = paths.map((path) => Math.max(path.getTotalLength(), 1));
      const totalLength = pathLengths.reduce((sum, length) => sum + length, 0);
      const timings = pathLengths.map((length) => (length / totalLength) * SIGNATURE_TOTAL_DURATION);
      const delays: number[] = [];
      let accumulatedDelay = 0;
      timings.forEach((duration, index) => {
        delays[index] = accumulatedDelay;
        accumulatedDelay += duration;
      });

      let replayInterval: number | undefined;
      let finishTimer: number | undefined;
      let cleanupRain = () => {};

      if (rainCanvas && !reduceMotion.matches) {
        cleanupRain = startRainCanvas(rainCanvas);
      }

      const finish = () => {
        signature.classList.add('has-drawn');
        rainLines?.setAttribute('data-visible', 'true');
      };

      const reset = () => {
        if (finishTimer) window.clearTimeout(finishTimer);
        finishTimer = undefined;
        signature.classList.remove('is-drawing', 'has-drawn');
        rainLines?.removeAttribute('data-visible');
        paths.forEach((path, index) => resetPath(path, pathLengths[index]));
        signature.dataset.signatureRun = `${Date.now()}-${Math.random().toString(36).slice(2)}`;
        void svg.getBoundingClientRect();
      };

      const play = () => {
        reset();

        if (reduceMotion.matches) {
          paths.forEach((path) => {
            path.style.transition = 'none';
            path.style.strokeDashoffset = '0';
          });
          finish();
          return;
        }

        window.requestAnimationFrame(() => {
          window.requestAnimationFrame(() => {
            signature.classList.add('is-drawing');
            paths.forEach((path, index) => drawPath(path, timings[index], delays[index]));
            finishTimer = window.setTimeout(finish, SIGNATURE_TOTAL_DURATION + 140);
          });
        });
      };

      const startReplayLoop = () => {
        if (replayInterval) window.clearInterval(replayInterval);
        replayInterval = window.setInterval(play, SIGNATURE_REPLAY_INTERVAL);
      };

      const stopReplayLoop = () => {
        if (replayInterval) window.clearInterval(replayInterval);
        replayInterval = undefined;
      };

      reset();

      const observer = new IntersectionObserver(
        ([entry]) => {
          if (entry.isIntersecting) {
            play();
            startReplayLoop();
          } else {
            stopReplayLoop();
          }
        },
        { threshold: 0.35 }
      );

      observer.observe(signature);

      document.addEventListener(
        'astro:before-swap',
        () => {
          stopReplayLoop();
          if (finishTimer) window.clearTimeout(finishTimer);
          cleanupRain();
          observer.disconnect();
        },
        { once: true }
      );
    });
  };

  initArticleSignatures();
  document.addEventListener('astro:page-load', initArticleSignatures);
</script>

<style>
  .letter-signature-area {
    position: relative;
    display: grid;
    gap: 10px;
    width: min(100% - 32px, 620px);
    margin: clamp(44px, 7vw, 72px) auto 0;
    padding: 18px 18px 14px;
    color: #171411;
    isolation: isolate;
  }

  .signature-rain-canvas {
    position: absolute;
    inset: 0;
    z-index: -1;
    width: 100%;
    height: 100%;
    pointer-events: none;
    opacity: 0.45;
  }

  .signature-svg-wrapper {
    width: min(100%, 420px);
    height: auto;
    aspect-ratio: 620 / 210;
    margin-inline: auto;
  }

  .rainy-signature-svg {
    display: block;
    overflow: visible;
  }

  .signature-path {
    fill: none;
    stroke: currentColor;
    stroke-width: 4px;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-miterlimit: 1.5;
    will-change: stroke-dashoffset;
  }

  .path-y-underline {
    stroke-width: 3.6px;
  }

  .signature-rain-lines {
    position: absolute;
    top: clamp(10px, 2.6vw, 18px);
    right: clamp(10px, 3vw, 22px);
    width: clamp(54px, 12vw, 88px);
    height: auto;
    color: #171411;
    opacity: 0;
    transform: translate3d(8px, -6px, 0);
    transition:
      opacity 560ms ease,
      transform 560ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .signature-rain-lines[data-visible='true'] {
    opacity: 0.55;
    transform: translateY(0);
  }

  .signature-rain-lines svg {
    display: block;
    width: 100%;
    height: auto;
  }

  .signature-rain-lines path {
    fill: none;
    stroke: currentColor;
    stroke-width: 4px;
    stroke-linecap: round;
  }

  .signature-slogan {
    display: grid;
    gap: 1px;
    justify-items: end;
    color: var(--color-muted);
    font-size: clamp(11px, 1.7vw, 14px);
    line-height: 1.65;
    text-align: right;
  }

  .signature-slogan p {
    margin: 0;
  }

  .slogan-primary {
    color: var(--color-text);
  }

  @media (max-width: 640px) {
    .letter-signature-area {
      width: min(100% - 24px, 440px);
      padding-inline: 6px;
    }

    .signature-svg-wrapper {
      width: min(100%, 320px);
    }

    .signature-rain-lines {
      right: 0;
      width: 54px;
    }

    .signature-slogan {
      justify-items: start;
      text-align: left;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .signature-rain-canvas {
      display: none;
    }

    .signature-path,
    .signature-rain-lines {
      transition: none !important;
    }
  }
</style>
