---
type Props = {
  title: string;
  description: string;
  pubDate: Date;
  category: string;
  tags: string[];
  href: string;
  index?: number;
};

const { title, description, pubDate, category, tags, href, index = 0 } = Astro.props;

const formattedDate = new Intl.DateTimeFormat("zh-CN", {
  year: "numeric",
  month: "2-digit",
  day: "2-digit",
}).format(pubDate);

const recordNumber = String(index + 1).padStart(2, "0");
---

<article class="post-card">
  <div class="post-card__titlebar">
    <span class="post-card__icon" aria-hidden="true"></span>
    <span class="post-card__filename">record-{recordNumber}.log</span>
    <span class="post-card__controls" aria-hidden="true">
      <span>_</span>
      <span>[]</span>
      <span>x</span>
    </span>
  </div>

  <a class="post-card__body" href={href}>
    <div class="post-card__meta">
      <span class="post-card__date">{formattedDate}</span>
      <span class="post-card__category">[{category}]</span>
    </div>

    <h2>{title}</h2>
    <p>{description}</p>

    <ul class="post-card__tags" aria-label={`${title} 标签`}>
      {tags.map((tag) => (
        <li>#{tag}</li>
      ))}
    </ul>
  </a>
</article>

<style>
  .post-card {
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.82), rgba(226, 244, 255, 0.64));
    border: 1px solid rgba(24, 92, 190, 0.58);
    border-radius: 14px;
    box-shadow:
      0 14px 30px rgba(16, 70, 132, 0.16),
      inset 0 1px 0 rgba(255, 255, 255, 0.92);
    overflow: hidden;
    transition: border-color 180ms ease, box-shadow 180ms ease, transform 180ms ease;
  }

  .post-card:hover {
    border-color: rgba(29, 102, 211, 0.82);
    box-shadow:
      0 20px 40px rgba(16, 70, 132, 0.24),
      inset 0 1px 0 rgba(255, 255, 255, 0.94);
    transform: translateY(-2px);
  }

  .post-card__titlebar {
    align-items: center;
    background:
      linear-gradient(180deg, var(--xp-title-blue-light, #64b7ff) 0%, var(--xp-title-blue, #1d66d3) 44%, var(--xp-title-blue-dark, #0c3f9e) 100%);
    border-bottom: 1px solid rgba(8, 48, 132, 0.45);
    color: #fff;
    display: flex;
    font-family: Tahoma, var(--font-mono);
    font-size: 0.78rem;
    gap: 0.5rem;
    min-height: 2rem;
    padding: 0 0.65rem;
    text-shadow: 0 1px 1px rgba(0, 28, 88, 0.55);
  }

  .post-card__icon {
    background:
      linear-gradient(145deg, #fff, rgba(255, 255, 255, 0.2)),
      linear-gradient(145deg, var(--color-xp-grass), var(--color-aero-cyan));
    border: 1px solid rgba(255, 255, 255, 0.72);
    border-radius: 4px;
    height: 1rem;
    width: 1rem;
  }

  .post-card__filename {
    flex: 1;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .post-card__controls {
    display: inline-flex;
    gap: 0.25rem;
  }

  .post-card__controls span {
    align-items: center;
    background: linear-gradient(180deg, #7dbdff, #397fe6);
    border: 1px solid rgba(255, 255, 255, 0.78);
    border-radius: 4px;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.62), 0 1px 2px rgba(0, 28, 80, 0.35);
    display: inline-flex;
    font-size: 0.55rem;
    height: 1rem;
    justify-content: center;
    line-height: 1;
    width: 1rem;
  }

  .post-card__controls span:last-child {
    background: linear-gradient(180deg, #ff9b8c, #d94c42);
    font-size: 0.74rem;
  }

  .post-card__body {
    color: var(--text-main);
    display: grid;
    gap: var(--space-3);
    padding: var(--space-5);
    text-decoration: none;
  }

  .post-card__meta {
    align-items: center;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    font-family: var(--font-mono);
    font-size: 0.78rem;
  }

  .post-card__date {
    color: var(--text-soft);
  }

  .post-card__category {
    background: rgba(255, 255, 255, 0.58);
    border: 1px solid rgba(42, 126, 231, 0.28);
    border-radius: 7px;
    color: var(--xp-title-blue, var(--color-system-blue));
    padding: 0.18rem 0.45rem;
  }

  .post-card h2 {
    font-size: clamp(1.35rem, 3vw, 2rem);
    margin: 0;
    overflow-wrap: anywhere;
  }

  .post-card p {
    color: var(--text-muted);
    margin: 0;
    overflow-wrap: anywhere;
  }

  .post-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    list-style: none;
    margin: var(--space-2) 0 0;
    padding: 0;
  }

  .post-card__tags li {
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.86), rgba(194, 235, 255, 0.62));
    border: 1px solid rgba(42, 126, 231, 0.42);
    border-radius: 999px;
    color: #0c4c9b;
    font-family: var(--font-mono);
    font-size: 0.76rem;
    max-width: 100%;
    overflow-wrap: anywhere;
    padding: 0.3rem 0.55rem;
  }

  @media (max-width: 640px) {
    .post-card__body {
      padding: var(--space-4);
    }

    .post-card__titlebar {
      font-size: 0.72rem;
    }
  }
</style>
