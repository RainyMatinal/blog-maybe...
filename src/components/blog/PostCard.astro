---
type Props = {
  title: string;
  description: string;
  pubDate: Date;
  category: string;
  tags: string[];
  href: string;
  heroImage?: string;
  index?: number;
};

const { title, description, pubDate, category, tags, href, heroImage, index = 0 } = Astro.props;
const formattedDate = new Intl.DateTimeFormat("en-US", { month: "short", day: "2-digit", year: "numeric" }).format(pubDate).toUpperCase();
const stampDate = new Intl.DateTimeFormat("en-US", { month: "short", day: "2-digit" }).format(pubDate).toUpperCase();
const wordCount = `${Math.max(360, Math.round((description.length + title.length) * 18))} WORDS`;
const themeColors = ["#142B42", "#B23A3A", "#1E3A8A", "#3ba69e", "#FF6F61"];
const themeColor = themeColors[index % themeColors.length];
---

<article class="ticket-card" style={`--card-theme-color: ${themeColor}; --stagger: ${index};`}>
  <div class="postmark-wrapper" aria-hidden="true">
    <div class="postmark-circle">
      <div class="postmark-inner">
        <span class="postmark-date">{stampDate}</span>
        <span class="postmark-location">RM</span>
      </div>
    </div>
    <div class="postmark-waves"></div>
  </div>

  <a class="ticket-image-zone" href={href} aria-label={title} data-search-title={title} data-search-desc={description}>
    {heroImage ? <img src={heroImage} alt="" loading="lazy" decoding="async" /> : <div class="placeholder-image" data-label="PLACEHOLDER COVER"></div>}
  </a>

  <div class="ticket-content">
    <div class="ticket-divider" aria-hidden="true"></div>
    <div class="meta">
      <div class="ribbon-wrapper postcard-ribbon">
        <span class="category-ribbon">{category}</span>
      </div>
      <span class="word-count">{wordCount}</span>
    </div>

    <h2 class="title"><a href={href}>{title}</a></h2>
    <p class="excerpt">{description}</p>
    {tags.length > 0 && (
      <ul class="ticket-tags" aria-label={`${title} tags`}>
        {tags.slice(0, 4).map((tag) => <li>#{tag}</li>)}
      </ul>
    )}
    <div class="postcard-stripe" aria-hidden="true"></div>
  </div>
</article>

<style>
  .ticket-card {
    --card-radius: 4px;
    --card-theme-color: #142b42;
    position: relative;
    display: flex;
    height: 100%;
    flex-direction: column;
    background: transparent;
    filter: drop-shadow(0 6px 10px rgba(20, 43, 66, 0.12));
    opacity: 1;
    transform: translateY(0);
    animation: dealCards 1.2s cubic-bezier(0.2, 0.8, 0.2, 1) both;
    animation-delay: calc(var(--stagger, 0) * 0.15s);
    transition: filter 0.5s cubic-bezier(0.2, 0.8, 0.2, 1), transform 0.5s cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  .ticket-card:hover {
    --card-radius: 2px;
    filter: drop-shadow(0 22px 6px rgba(20, 43, 66, 0.25)) !important;
    transform: translateY(-16px);
  }

  .ticket-image-zone {
    width: 100%;
    aspect-ratio: 3 / 2;
    overflow: hidden;
    background: #fff;
    border-radius: var(--card-radius) var(--card-radius) 0 0;
    mask-image: radial-gradient(circle at 0% 100%, transparent 8px, black 8.5px), radial-gradient(circle at 100% 100%, transparent 8px, black 8.5px);
    mask-position: left, right;
    mask-repeat: no-repeat;
    mask-size: 51% 100%;
    transition: border-radius 0.4s ease;
  }

  .ticket-image-zone img,
  .ticket-image-zone .placeholder-image {
    width: 100%;
    height: 100%;
    min-height: 0;
    object-fit: cover;
    transition: transform 1.2s ease, filter 0.5s ease;
  }

  .ticket-card:hover .ticket-image-zone img,
  .ticket-card:hover .ticket-image-zone .placeholder-image {
    transform: scale(1.05);
  }

  .ticket-content {
    position: relative;
    display: flex;
    flex-grow: 1;
    flex-direction: column;
    padding: 1.5rem 1.8rem 2rem;
    background: #fff;
    border-radius: 0 0 var(--card-radius) var(--card-radius);
    mask-image: radial-gradient(circle at 0% 0%, transparent 8px, black 8.5px), radial-gradient(circle at 100% 0%, transparent 8px, black 8.5px);
    mask-position: left, right;
    mask-repeat: no-repeat;
    mask-size: 51% 100%;
    transition: border-radius 0.4s ease;
  }

  .ticket-divider {
    position: absolute;
    top: -1.5px;
    left: 16px;
    right: 16px;
    z-index: 10;
    height: 3px;
    background-image: linear-gradient(to right, #c4c1b8 40%, transparent 40%);
    background-repeat: repeat-x;
    background-size: 14px 3px;
  }

  .meta {
    display: flex;
    align-items: center;
    justify-content: flex-start;
    gap: 1.2rem;
    height: 28px;
    margin-bottom: 1.5rem;
  }

  .ribbon-wrapper {
    display: inline-block;
    filter: drop-shadow(3px 4px 5px rgba(0, 0, 0, 0.3));
    transition: all 0.5s ease;
  }

  .postcard-ribbon {
    margin-left: -1.8rem;
  }

  .ticket-card:hover .postcard-ribbon {
    filter: drop-shadow(5px 6px 8px rgba(0, 0, 0, 0.4));
  }

  .category-ribbon {
    display: block;
    background: var(--card-theme-color);
    clip-path: polygon(0 0, 100% 0, 85% 50%, 100% 100%, 0 100%);
    color: #fff;
    font-size: 0.8rem;
    font-weight: 900;
    padding: 4px 16px 4px 12px;
    text-decoration: none;
    transition: background-color 0.5s ease;
  }

  .word-count {
    opacity: 0;
    transform: scale(1.4) rotate(-8deg);
    color: var(--card-theme-color);
    border: 2px solid var(--card-theme-color);
    border-radius: 2px;
    background: transparent;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    mix-blend-mode: multiply;
    padding: 2px 6px;
    pointer-events: none;
    transition: all 0.35s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }

  .ticket-card:hover .word-count {
    opacity: 0.85;
    transform: scale(1);
  }

  .title {
    font-family: var(--font-base);
    font-size: 1.4rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    line-height: 1.4;
    margin: 0 0 1rem;
    text-autospace: none;
    -webkit-text-autospace: none;
  }

  .title a {
    color: #111;
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .title a:hover {
    color: var(--card-theme-color);
  }

  .excerpt {
    display: -webkit-box;
    overflow: hidden;
    color: #666;
    font-size: 0.95rem;
    line-height: 1.7;
    margin: 0;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 3;
  }

  .ticket-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    list-style: none;
    margin: 1.2rem 0 0;
    padding: 0;
  }

  .ticket-tags li {
    color: #999;
    font-size: 0.8rem;
    font-weight: 700;
  }

  .postcard-stripe {
    position: absolute;
    right: 0;
    bottom: 0;
    left: 0;
    height: 4px;
    border-radius: 0 0 var(--card-radius) var(--card-radius);
    background: transparent;
    opacity: 0;
    transition: all 0.5s ease;
  }

  .ticket-card:hover .postcard-stripe {
    opacity: 1;
    background: repeating-linear-gradient(-45deg, var(--theme-red), var(--theme-red) 15px, transparent 15px, transparent 20px, var(--theme-blue) 20px, var(--theme-blue) 35px, transparent 35px, transparent 40px);
  }

  .postmark-wrapper {
    position: absolute;
    top: 15px;
    right: 15px;
    z-index: 20;
    display: flex;
    align-items: center;
    opacity: 0;
    mix-blend-mode: multiply;
    pointer-events: none;
    transform: translate(10px, -10px) rotate(15deg) scale(1.1);
    transition: all 0.6s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }

  .ticket-card:hover .postmark-wrapper {
    opacity: 0.9;
    transform: translate(0) rotate(-6deg) scale(1);
  }

  .postmark-circle {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 80px;
    height: 80px;
    border: 2px solid var(--card-theme-color);
    border-radius: 50%;
    padding: 4px;
    transition: border-color 0.5s ease;
  }

  .postmark-inner {
    display: flex;
    width: 100%;
    height: 100%;
    flex: 1;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    border: 1px dashed var(--card-theme-color);
    border-radius: 50%;
    color: var(--card-theme-color);
    transition: border-color 0.5s ease, color 0.5s ease;
  }

  .postmark-date {
    font-size: 0.65rem;
    font-weight: 700;
    line-height: 1;
    margin-bottom: 2px;
  }

  .postmark-location {
    border-top: 1px solid var(--card-theme-color);
    font-size: 0.5rem;
    letter-spacing: 2px;
    padding-top: 2px;
  }

  .postmark-waves {
    width: 45px;
    height: 32px;
    margin-left: -10px;
    background-color: var(--card-theme-color);
    mask-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 45 30' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M0 6 Q 5 2, 10 6 T 20 6 T 30 6 T 40 6 M0 15 Q 5 11, 10 15 T 20 15 T 30 15 T 40 15 M0 24 Q 5 20, 10 24 T 20 24 T 30 24 T 40 24' fill='none' stroke='black' stroke-width='2.5'/%3E%3C/svg%3E");
    mask-repeat: no-repeat;
    -webkit-mask-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 45 30' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M0 6 Q 5 2, 10 6 T 20 6 T 30 6 T 40 6 M0 15 Q 5 11, 10 15 T 20 15 T 30 15 T 40 15 M0 24 Q 5 20, 10 24 T 20 24 T 30 24 T 40 24' fill='none' stroke='black' stroke-width='2.5'/%3E%3C/svg%3E");
    -webkit-mask-repeat: no-repeat;
    transition: background-color 0.5s ease;
  }
</style>
<style is:global>
  @media (prefers-reduced-motion: reduce) {
    .ticket-card {
      opacity: 1 !important;
      transform: none !important;
      animation: none !important;
    }
  }
</style>