---
type Props = {
  title: string;
  description: string;
  pubDate: Date;
  category: string;
  tags: string[];
  href: string;
  index?: number;
};

const { title, description, pubDate, category, tags, href, index = 0 } = Astro.props;

const formattedDate = new Intl.DateTimeFormat("zh-CN", {
  year: "numeric",
  month: "2-digit",
  day: "2-digit",
}).format(pubDate);

const recordNumber = String(index + 1).padStart(2, "0");
---

<article class="post-card">
  <div class="post-card__titlebar window-titlebar">
    <span class="window-dot dot-red" aria-hidden="true"></span>
    <span class="window-dot dot-yellow" aria-hidden="true"></span>
    <span class="window-dot dot-green" aria-hidden="true"></span>
    <span class="post-card__filename">record-{recordNumber}.log</span>
  </div>

  <a class="post-card__body" href={href}>
    <div class="post-card__meta">
      <span class="post-card__date">{formattedDate}</span>
      <span class="post-card__category">[{category}]</span>
    </div>

    <h2>{title}</h2>
    <p>{description}</p>

    <ul class="post-card__tags" aria-label={`${title} 标签`}>
      {tags.map((tag) => (
        <li><span class="tag">#{tag}</span></li>
      ))}
    </ul>
  </a>
</article>

<style>
  .post-card {
    background: var(--bg-window);
    border: 1px solid var(--border-window);
    border-radius: var(--radius-window);
    box-shadow: var(--shadow-glass), var(--shadow-inset);
    overflow: hidden;
    transition: border-color 180ms ease, box-shadow 180ms ease, transform 180ms ease;
  }

  .post-card:hover {
    border-color: rgba(111, 255, 233, 0.72);
    box-shadow: var(--shadow-hover), var(--shadow-inset);
    transform: translateY(-2px);
  }

  .post-card__titlebar {
    align-items: center;
    background: var(--bg-titlebar);
    border-bottom: 1px solid rgba(94, 200, 255, 0.32);
    color: var(--text-muted);
    display: flex;
    font-family: var(--font-ui);
    font-size: 0.78rem;
    gap: 0.5rem;
    min-height: 2rem;
    padding: 0 0.65rem;
    text-shadow: 0 1px 0 rgba(255, 255, 255, 0.75);
  }


  .post-card__filename {
    flex: 1;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }


  .post-card__body {
    color: var(--text-main);
    display: grid;
    gap: var(--space-3);
    padding: var(--space-5);
    text-decoration: none;
  }

  .post-card__meta {
    align-items: center;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    font-family: var(--font-mono);
    font-size: 0.78rem;
  }

  .post-card__date {
    color: var(--text-soft);
  }

  .post-card__category {
    background: var(--bg-control);
    border: 1px solid var(--border-control);
    border-radius: var(--radius-control);
    color: var(--color-deep-teal);
    padding: 0.18rem 0.45rem;
  }

  .post-card h2 {
    font-size: clamp(1.35rem, 3vw, 2rem);
    margin: 0;
    overflow-wrap: anywhere;
  }

  .post-card p {
    color: var(--text-muted);
    margin: 0;
    overflow-wrap: anywhere;
  }

  .post-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    list-style: none;
    margin: var(--space-2) 0 0;
    padding: 0;
  }

  .post-card__tags .tag {
    font-size: 0.76rem;
  }

  @media (max-width: 640px) {
    .post-card__body {
      padding: var(--space-4);
    }

    .post-card__titlebar {
      font-size: 0.72rem;
    }
  }
</style>
