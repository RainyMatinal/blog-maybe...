---
import type { Lang } from '@/i18n/ui';

interface Props {
  lang: Lang;
  title: string;
  subtitle: string;
}

const { lang, title, subtitle } = Astro.props;
---

<section class="notes-shell" data-notes-app data-lang={lang}>
  <header class="notes-head site-shell">
    <div>
      <p class="eyebrow ui-font">{subtitle}</p>
      <h1 class="ui-font">{title}</h1>
    </div>
    <div class="notes-meta ui-font">
      <span data-note-count>0</span>
      <span>{lang === 'zh' ? '可见 / 可编辑' : 'Visible / Editable'}</span>
    </div>
  </header>

  <section class="site-shell notes-intro">
    <p>
      {lang === 'zh'
        ? '不登录可以看，登录后才可以发布、修改和删除。新增笔记会轻微扰动最近 3 天的块位，旧笔记保持稳定。'
        : 'You can browse without signing in. After login you can publish, edit, and delete. New notes slightly reshuffle the last 3 days only, while older notes stay fixed.'}
    </p>
  </section>

  <section class="site-shell notes-tools">
    <label class="notes-search ui-font">
      <span>{lang === 'zh' ? '查询' : 'Search'}</span>
      <input
        type="search"
        data-notes-search
        placeholder={lang === 'zh' ? '搜日期、关键词、片段' : 'Search date, keyword, fragment'}
      />
    </label>
    <p class="notes-search-meta ui-font" data-search-meta></p>
  </section>

  <section class="site-shell notes-board" data-notes-board aria-label={title}></section>

  <aside class="notes-auth" data-auth-panel>
    <button class="auth-badge ui-font" type="button" data-auth-toggle>
      {lang === 'zh' ? '登录' : 'Login'}
    </button>
    <form class="auth-card" data-auth-form>
      <h2 class="ui-font">{lang === 'zh' ? '写笔记' : 'Write Notes'}</h2>
      <label>
        <span>{lang === 'zh' ? '账号' : 'Account'}</span>
        <input type="email" name="email" autocomplete="username" required />
      </label>
      <label>
        <span>{lang === 'zh' ? '密码' : 'Password'}</span>
        <input type="password" name="password" autocomplete="current-password" required />
      </label>
      <label>
        <span>{lang === 'zh' ? '验证码' : 'Captcha'}</span>
        <div class="captcha-row">
          <input type="text" name="captcha" inputmode="numeric" required />
          <button class="captcha-chip ui-font" type="button" data-captcha-chip></button>
        </div>
      </label>
      <div class="auth-actions">
        <button class="primary ui-font" type="submit">{lang === 'zh' ? '进入' : 'Enter'}</button>
        <button class="ghost ui-font" type="button" data-auth-close>{lang === 'zh' ? '关闭' : 'Close'}</button>
      </div>
      <p class="auth-hint">{lang === 'zh' ? '登录后内容只保存在当前浏览器。' : 'Content is saved only in this browser.'}</p>
    </form>
  </aside>

  <button class="compose-fab ui-font" type="button" data-compose-fab hidden>
    {lang === 'zh' ? '新建' : 'New'}
  </button>

  <dialog class="compose-dialog" data-compose-dialog>
    <form method="dialog" class="compose-card" data-compose-form>
      <h2 class="ui-font">{lang === 'zh' ? '编辑笔记' : 'Edit Note'}</h2>
      <label>
        <span>{lang === 'zh' ? '内容' : 'Content'}</span>
        <textarea name="content" rows="8" required></textarea>
      </label>
      <div class="compose-actions">
        <button class="primary ui-font" value="save" type="submit">{lang === 'zh' ? '保存' : 'Save'}</button>
        <button class="ghost ui-font" value="cancel" type="button" data-compose-cancel>{lang === 'zh' ? '取消' : 'Cancel'}</button>
      </div>
    </form>
  </dialog>

  <dialog class="note-view-dialog" data-view-dialog>
    <article class="note-view-card">
      <button class="note-view-close ui-font" type="button" data-view-close>
        {lang === 'zh' ? '关闭' : 'Close'}
      </button>
      <div class="note-view-meta ui-font">
        <span data-view-date></span>
        <span data-view-state></span>
      </div>
      <p data-view-content></p>
      <div class="note-view-actions">
        <button class="primary ui-font" type="button" data-view-edit hidden>
          {lang === 'zh' ? '编辑' : 'Edit'}
        </button>
      </div>
    </article>
  </dialog>

  <dialog class="confirm-dialog" data-confirm-dialog>
    <form method="dialog" class="confirm-card">
      <h2 class="ui-font">{lang === 'zh' ? '确认删除？' : 'Delete this note?'}</h2>
      <p data-confirm-text></p>
      <div class="confirm-actions">
        <button class="ghost ui-font" value="cancel" type="button" data-confirm-cancel>
          {lang === 'zh' ? '取消' : 'Cancel'}
        </button>
        <button class="danger ui-font" value="delete" type="button" data-confirm-delete>
          {lang === 'zh' ? '删除' : 'Delete'}
        </button>
      </div>
    </form>
  </dialog>

  <script is:inline>
    const STORAGE_KEY = 'notes-board-v1';
    const AUTH_KEY = 'notes-auth-v1';
    const KNOWN_USER = '15372028397@163.com';
    const PASSWORD_HASH = 'a2b8862b692f5b07a36cbc20bfb870b200380e7f431c579411c39fdca50b970b';

    const root = document.querySelector('[data-notes-app]');
    if (!root) throw new Error('Missing notes app root');

    const lang = root.dataset.lang === 'en' ? 'en' : 'zh';
    const board = root.querySelector('[data-notes-board]');
    const countEl = root.querySelector('[data-note-count]');
    const authPanel = root.querySelector('[data-auth-panel]');
    const authForm = root.querySelector('[data-auth-form]');
    const authToggle = root.querySelector('[data-auth-toggle]');
    const authClose = root.querySelector('[data-auth-close]');
    const captchaChip = root.querySelector('[data-captcha-chip]');
    const fab = root.querySelector('[data-compose-fab]');
    const searchInput = root.querySelector('[data-notes-search]');
    const searchMeta = root.querySelector('[data-search-meta]');
    const composeDialog = root.querySelector('[data-compose-dialog]');
    const composeForm = root.querySelector('[data-compose-form]');
    const composeCancel = root.querySelector('[data-compose-cancel]');
    const viewDialog = root.querySelector('[data-view-dialog]');
    const viewClose = root.querySelector('[data-view-close]');
    const viewDate = root.querySelector('[data-view-date]');
    const viewState = root.querySelector('[data-view-state]');
    const viewContent = root.querySelector('[data-view-content]');
    const viewEdit = root.querySelector('[data-view-edit]');
    const confirmDialog = root.querySelector('[data-confirm-dialog]');
    const confirmText = root.querySelector('[data-confirm-text]');
    const confirmCancel = root.querySelector('[data-confirm-cancel]');
    const confirmDelete = root.querySelector('[data-confirm-delete]');

    const ui = {
      zh: {
        loginFail: '账号、密码或验证码不对',
        noteEmpty: '还没有笔记，先写一条吧。',
        noResult: '没有找到匹配的笔记。',
        searchCount: (shown, total) => `找到 ${shown} / ${total} 条`,
        recent: '最近 3 天',
        archive: '归档',
        drag: '拖动',
        open: '放大',
        confirmDelete: (text) => `确定删除这条笔记吗？「${text}」`,
        edit: '编辑',
        del: '删除'
      },
      en: {
        loginFail: 'Wrong account, password, or captcha',
        noteEmpty: 'No notes yet. Write the first one.',
        noResult: 'No matching notes.',
        searchCount: (shown, total) => `${shown} / ${total} notes found`,
        recent: 'Last 3 days',
        archive: 'Archive',
        drag: 'Drag',
        open: 'Open',
        confirmDelete: (text) => `Delete this note? "${text}"`,
        edit: 'Edit',
        del: 'Delete'
      }
    }[lang];

    const seedCaptcha = () => Math.floor(1000 + Math.random() * 9000).toString();

    const seeded = (input) => {
      let h = 2166136261;
      for (let i = 0; i < input.length; i++) {
        h ^= input.charCodeAt(i);
        h = Math.imul(h, 16777619);
      }
      return () => {
        h += h << 13;
        h ^= h >>> 7;
        h += h << 3;
        h ^= h >>> 17;
        h += h << 5;
        return (h >>> 0) / 4294967296;
      };
    };

    const today = Date.now();
    const day = 86400000;

    const loadNotes = () => {
      try {
        const raw = localStorage.getItem(STORAGE_KEY);
        const parsed = raw ? JSON.parse(raw) : null;
        if (Array.isArray(parsed)) return parsed;
      } catch {}
      const at = (offset) => new Date(today - offset * day).toISOString();
      return [
        { id: 'a', createdAt: at(0), updatedAt: at(0), content: lang === 'zh' ? '今天先放一块柔软的蓝色。' : 'Put a soft blue block here today.' },
        { id: 'b', createdAt: at(1), updatedAt: at(1), content: lang === 'zh' ? '昨天记下一个更轻的标题。' : 'Yesterday I noted a lighter headline.' },
        { id: 'c', createdAt: at(2), updatedAt: at(2), content: lang === 'zh' ? '再往前一点，排版开始变得安静。' : 'A bit further back, the layout grows quiet.' },
        { id: 'd', createdAt: at(5), updatedAt: at(5), content: lang === 'zh' ? '更早的笔记会稳稳留在原地。' : 'Older notes keep their place.' },
        { id: 'e', createdAt: at(10), updatedAt: at(10), content: lang === 'zh' ? '旧段落像贴在墙上的便签。' : 'Old paragraphs stick like notes on a wall.' }
      ];
    };

    const saveNotes = (notes) => localStorage.setItem(STORAGE_KEY, JSON.stringify(notes));
    const loadAuth = () => localStorage.getItem(AUTH_KEY) === '1';
    const saveAuth = (value) => localStorage.setItem(AUTH_KEY, value ? '1' : '0');
    const ageDays = (date) => Math.floor((Date.now() - new Date(date).getTime()) / day);
    const isActive = (note) => ageDays(note.updatedAt || note.createdAt) < 3;
    const isNarrow = () => matchMedia('(max-width: 720px)').matches;
    const normalize = (value) => String(value || '').trim().toLocaleLowerCase();

    const matchesSearch = (note) => {
      if (!searchTerm) return true;
      const status = isActive(note) ? ui.recent : ui.archive;
      const haystack = normalize(`${note.content} ${noteTime(note)} ${status}`);
      return haystack.includes(searchTerm);
    };

    const notePosition = (note) => {
      if (!note.position) return null;
      const x = Number(note.position.x);
      const y = Number(note.position.y);
      if (!Number.isFinite(x) || !Number.isFinite(y)) return null;
      return { x, y };
    };

    const boardColumns = () => {
      if (!board) return 3;
      if (board.clientWidth < 860) return 2;
      return 3;
    };

    const boardHeightFor = (visible, archivedCount, activeCount) => {
      const columns = boardColumns();
      const rows = Math.ceil(archivedCount / columns) + Math.ceil(activeCount / columns);
      const autoHeight = Math.max(760, 130 + rows * 250);
      const manualHeight = visible.reduce((max, note) => {
        const position = notePosition(note);
        return position ? Math.max(max, position.y + 260) : max;
      }, 0);
      return Math.max(autoHeight, manualHeight);
    };

    const palettes = [
      'var(--color-accent)',
      'var(--color-accent-2)',
      'var(--color-accent-3)',
      'var(--color-surface-strong)'
    ];

    const buildPalette = (rand, active) => {
      const accent = palettes[Math.floor(rand() * palettes.length)];
      const fill = active
        ? `color-mix(in srgb, ${accent} ${58 + rand() * 12}%, var(--color-surface))`
        : `color-mix(in srgb, ${accent} ${30 + rand() * 10}%, var(--color-surface))`;
      return { accent, fill };
    };

    const hash = async (value) => {
      const bytes = new TextEncoder().encode(value);
      const digest = await crypto.subtle.digest('SHA-256', bytes);
      return Array.from(new Uint8Array(digest)).map((n) => n.toString(16).padStart(2, '0')).join('');
    };

    let notes = loadNotes();
    let authed = loadAuth();
    let captcha = seedCaptcha();
    let editingId = null;
    let viewingId = null;
    let deletingId = null;
    let searchTerm = '';
    let boardRect = null;
    let dragState = null;

    const splitNotes = (list = notes) => {
      const active = [];
      const archived = [];
      for (const note of [...list].sort((a, b) => new Date(b.updatedAt).getTime() - new Date(a.updatedAt).getTime())) {
        if (isActive(note)) active.push(note);
        else archived.push(note);
      }
      return { active, archived };
    };

    const autoLayout = (note, index, rowOffset, active) => {
      const columns = boardColumns();
      const rand = active
        ? seeded(`active-group|${notes.filter((item) => isActive(item)).length}|${note.id}|${note.content}|${note.updatedAt}`)
        : seeded(`archive|${note.id}|${note.createdAt}`);
      const width = active ? 230 + rand() * 86 : 190 + rand() * 70;
      const maxX = Math.max(32, (board?.clientWidth || 1120) - width - 64);
      const col = index % columns;
      const row = Math.floor(index / columns) + rowOffset;
      const colStep = columns === 1 ? 0 : maxX / (columns - 1);
      const x = 32 + col * colStep + rand() * 18 - 9;
      const y = 42 + row * 238 + rand() * 24;
      const rotate = active ? rand() * 8 - 4 : rand() * 4 - 2;
      const scale = active ? 1 + rand() * 0.12 : 0.95;
      const palette = buildPalette(rand, active);
      const outline = active ? palette.accent : 'var(--color-border)';
      return { width, x, y, rotate, scale, fill: palette.fill, accent: palette.accent, outline };
    };

    const layoutActive = (note, index, total, rowOffset) => {
      const manual = notePosition(note);
      if (manual && !isNarrow()) {
        const auto = autoLayout(note, index, rowOffset, true);
        return { ...auto, x: manual.x, y: manual.y, z: 30 + index };
      }
      const groupSeed = `active-group|${total}|${notes.filter((item) => isActive(item)).length}`;
      const rand = seeded(`${groupSeed}|${note.id}|${note.content}|${note.updatedAt}`);
      const base = autoLayout(note, index, rowOffset, true);
      const palette = buildPalette(rand, true);
      const outline = palette.accent;
      return { ...base, fill: palette.fill, accent: palette.accent, outline, z: 30 + index };
    };

    const layoutArchived = (note, index) => {
      const manual = notePosition(note);
      if (manual && !isNarrow()) {
        const auto = autoLayout(note, index, 0, false);
        return { ...auto, x: manual.x, y: manual.y, z: 1 + index };
      }
      const rand = seeded(`archive|${note.id}|${note.createdAt}`);
      const base = autoLayout(note, index, 0, false);
      const palette = buildPalette(rand, false);
      const fill = palette.fill;
      const outline = 'var(--color-border)';
      return { ...base, fill, accent: palette.accent, outline, z: 1 + index };
    };

    const noteTime = (note) => new Date(note.updatedAt || note.createdAt).toLocaleDateString(lang === 'zh' ? 'zh-CN' : 'en-US', {
      month: 'short',
      day: 'numeric'
    });

    const render = () => {
      const visible = notes.filter(matchesSearch);
      const { active, archived } = splitNotes(visible);
      countEl.textContent = String(visible.length);
      if (searchMeta) {
        searchMeta.textContent = searchTerm ? ui.searchCount(visible.length, notes.length) : '';
      }
      board.innerHTML = '';
      board.style.removeProperty('--notes-board-height');

      if (!visible.length) {
        board.innerHTML = `<p class="notes-empty">${notes.length ? ui.noResult : ui.noteEmpty}</p>`;
        return;
      }

      board.style.setProperty('--notes-board-height', `${boardHeightFor(visible, archived.length, active.length)}px`);
      const fragments = [];
      archived.forEach((note, index) => {
        const layout = layoutArchived(note, index);
        fragments.push(noteCard(note, layout));
      });
      const activeRowOffset = Math.ceil(archived.length / boardColumns());
      active.forEach((note, index) => {
        const layout = layoutActive(note, index, active.length, activeRowOffset);
        fragments.push(noteCard(note, layout));
      });
      fragments.forEach((el) => board.appendChild(el));
    };

    const noteCard = (note, layout) => {
      const article = document.createElement('article');
      article.className = 'note-block';
      article.dataset.id = note.id;
      article.dataset.state = isActive(note) ? 'recent' : 'archive';
      article.style.setProperty('--note-x', `${layout.x}px`);
      article.style.setProperty('--note-y', `${layout.y}px`);
      article.style.setProperty('--note-rotate', `${layout.rotate}deg`);
      article.style.setProperty('--note-scale', `${layout.scale}`);
      article.style.setProperty('--note-width', `${layout.width}px`);
      article.style.setProperty('--note-fill', layout.fill);
      article.style.setProperty('--note-accent', layout.accent);
      article.style.setProperty('--note-outline', layout.outline);
      article.style.setProperty('--note-z', String(layout.z));
      article.setAttribute('tabindex', '0');
      article.setAttribute('aria-label', `${ui.open}: ${note.content}`);

      const head = document.createElement('div');
      head.className = 'note-head';

      const dragHandle = document.createElement('div');
      dragHandle.className = `note-drag-handle ui-font ${authed ? '' : 'is-locked'}`;
      dragHandle.dataset.dragHandle = note.id;
      dragHandle.title = ui.drag;
      dragHandle.textContent = ui.drag;

      const chip = document.createElement('span');
      chip.className = 'note-chip ui-font';
      chip.textContent = noteTime(note);

      const state = document.createElement('span');
      state.className = 'note-state ui-font';
      state.textContent = isActive(note) ? ui.recent : ui.archive;

      head.append(dragHandle, chip, state);

      const content = document.createElement('p');
      content.textContent = note.content;

      const tail = document.createElement('div');
      tail.className = 'note-tail';

      const trace = document.createElement('span');
      trace.className = 'note-trace';
      trace.setAttribute('aria-hidden', 'true');

      const controls = document.createElement('div');
      controls.className = `note-controls ${authed ? '' : 'is-hidden'}`;

      const edit = document.createElement('button');
      edit.type = 'button';
      edit.dataset.edit = note.id;
      edit.className = 'ui-font';
      edit.textContent = ui.edit;

      const del = document.createElement('button');
      del.type = 'button';
      del.dataset.del = note.id;
      del.className = 'ui-font';
      del.textContent = ui.del;

      controls.append(edit, del);
      tail.append(trace, controls);
      article.append(head, content, tail);
      return article;
    };

    const openComposer = (noteId = null) => {
      if (!authed) return;
      editingId = noteId;
      const note = notes.find((item) => item.id === noteId);
      composeForm.content.value = note?.content || '';
      composeDialog.showModal();
    };

    const closeComposer = () => {
      if (composeDialog.open) composeDialog.close();
    };

    const openViewer = (noteId) => {
      const note = notes.find((item) => item.id === noteId);
      if (!note) return;
      viewingId = noteId;
      viewDate.textContent = noteTime(note);
      viewState.textContent = isActive(note) ? ui.recent : ui.archive;
      viewContent.textContent = note.content;
      viewEdit.hidden = !authed;
      viewDialog.showModal();
    };

    const closeViewer = () => {
      viewingId = null;
      if (viewDialog.open) viewDialog.close();
    };

    const requestDelete = (noteId) => {
      const note = notes.find((item) => item.id === noteId);
      if (!note || !authed) return;
      deletingId = noteId;
      const preview = String(note.content).replace(/\s+/g, ' ').slice(0, 32);
      confirmText.textContent = ui.confirmDelete(preview);
      confirmDialog.showModal();
    };

    const closeConfirm = () => {
      deletingId = null;
      if (confirmDialog.open) confirmDialog.close();
    };

    const deleteConfirmed = () => {
      if (!deletingId || !authed) return;
      notes = notes.filter((note) => note.id !== deletingId);
      saveNotes(notes);
      if (viewingId === deletingId) closeViewer();
      closeConfirm();
      render();
    };

    const syncAuthUI = () => {
      fab.hidden = !authed;
      authPanel.hidden = authed;
      if (authed) authPanel.classList.remove('is-open');
      if (viewEdit) viewEdit.hidden = !authed || !viewingId;
    };

    const refreshCaptcha = () => {
      captcha = seedCaptcha();
      captchaChip.textContent = captcha;
    };

    authToggle?.addEventListener('click', () => authPanel.classList.add('is-open'));
    authClose?.addEventListener('click', () => authPanel.classList.remove('is-open'));
    captchaChip?.addEventListener('click', refreshCaptcha);
    fab?.addEventListener('click', () => openComposer());
    composeCancel?.addEventListener('click', closeComposer);
    viewClose?.addEventListener('click', closeViewer);
    viewEdit?.addEventListener('click', () => {
      if (!viewingId || !authed) return;
      closeViewer();
      openComposer(viewingId);
    });
    confirmCancel?.addEventListener('click', closeConfirm);
    confirmDelete?.addEventListener('click', deleteConfirmed);
    searchInput?.addEventListener('input', (event) => {
      searchTerm = normalize(event.target.value);
      render();
    });

    authForm?.addEventListener('submit', async (event) => {
      event.preventDefault();
      const form = new FormData(authForm);
      const email = String(form.get('email') || '').trim();
      const password = String(form.get('password') || '');
      const typedCaptcha = String(form.get('captcha') || '').trim();
      const secret = await hash(`${email}:${password}`);
      if (email === KNOWN_USER && secret === PASSWORD_HASH && typedCaptcha === captcha) {
        authed = true;
        saveAuth(true);
        syncAuthUI();
        render();
        refreshCaptcha();
      } else {
        alert(ui.loginFail);
        refreshCaptcha();
      }
    });

    composeForm?.addEventListener('submit', (event) => {
      event.preventDefault();
      if (!authed) return;
      const form = new FormData(composeForm);
      const content = String(form.get('content') || '').trim();
      if (!content) return;
      const now = new Date().toISOString();
      if (editingId) {
        notes = notes.map((note) => note.id === editingId ? { ...note, content, updatedAt: now } : note);
      } else {
        notes = [{ id: crypto.randomUUID(), createdAt: now, updatedAt: now, content }, ...notes];
      }
      saveNotes(notes);
      render();
      closeComposer();
      editingId = null;
    });

    board?.addEventListener('click', (event) => {
      const target = event.target;
      if (!(target instanceof HTMLElement)) return;
      const editId = target.dataset.edit;
      const delId = target.dataset.del;
      const dragHandle = target.closest('[data-drag-handle]');
      if (dragHandle && authed) return;
      if (editId && authed) openComposer(editId);
      if (delId && authed) requestDelete(delId);
      if (editId || delId) return;
      const card = target.closest('.note-block');
      if (card?.dataset.id) openViewer(card.dataset.id);
    });

    board?.addEventListener('keydown', (event) => {
      const target = event.target;
      if (!(target instanceof HTMLElement) || !target.classList.contains('note-block')) return;
      if ((event.key === 'Enter' || event.key === ' ') && target.dataset.id) {
        event.preventDefault();
        openViewer(target.dataset.id);
      }
    });

    board?.addEventListener('pointerdown', (event) => {
      const target = event.target;
      if (!(target instanceof HTMLElement) || !authed || isNarrow()) return;
      const handle = target.closest('[data-drag-handle]');
      if (!(handle instanceof HTMLElement)) return;
      const card = handle.closest('.note-block');
      if (!(card instanceof HTMLElement) || !card.dataset.id || !board) return;
      event.preventDefault();
      boardRect = board.getBoundingClientRect();
      const rect = card.getBoundingClientRect();
      dragState = {
        id: card.dataset.id,
        pointerId: event.pointerId,
        offsetX: event.clientX - rect.left,
        offsetY: event.clientY - rect.top
      };
      card.classList.add('is-dragging');
      card.setPointerCapture(event.pointerId);
    });

    board?.addEventListener('pointermove', (event) => {
      if (!dragState || !boardRect || !board) return;
      const card = board.querySelector(`[data-id="${CSS.escape(dragState.id)}"]`);
      if (!(card instanceof HTMLElement)) return;
      const maxX = Math.max(0, board.clientWidth - card.offsetWidth - 26);
      const maxY = Math.max(0, board.clientHeight - card.offsetHeight - 26);
      const x = Math.min(maxX, Math.max(18, event.clientX - boardRect.left - dragState.offsetX));
      const y = Math.min(maxY, Math.max(18, event.clientY - boardRect.top - dragState.offsetY));
      card.style.setProperty('--note-x', `${x}px`);
      card.style.setProperty('--note-y', `${y}px`);
    });

    const finishDrag = () => {
      if (!dragState || !boardRect || !board) return;
      const card = board.querySelector(`[data-id="${CSS.escape(dragState.id)}"]`);
      if (card instanceof HTMLElement) {
        const rect = card.getBoundingClientRect();
        const x = Math.round(rect.left - boardRect.left);
        const y = Math.round(rect.top - boardRect.top);
        notes = notes.map((note) => note.id === dragState.id ? { ...note, position: { x, y } } : note);
        saveNotes(notes);
        card.classList.remove('is-dragging');
        if (card.hasPointerCapture?.(dragState.pointerId)) {
          card.releasePointerCapture(dragState.pointerId);
        }
        render();
      }
      dragState = null;
      boardRect = null;
    };

    board?.addEventListener('pointerup', finishDrag);
    board?.addEventListener('pointercancel', finishDrag);

    viewDialog?.addEventListener('click', (event) => {
      const rect = viewDialog.getBoundingClientRect();
      const inside = rect.top <= event.clientY && event.clientY <= rect.top + rect.height && rect.left <= event.clientX && event.clientX <= rect.left + rect.width;
      if (!inside) closeViewer();
    });

    confirmDialog?.addEventListener('click', (event) => {
      const rect = confirmDialog.getBoundingClientRect();
      const inside = rect.top <= event.clientY && event.clientY <= rect.top + rect.height && rect.left <= event.clientX && event.clientX <= rect.left + rect.width;
      if (!inside) closeConfirm();
    });

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape' && composeDialog.open) {
        closeComposer();
      }
      if (event.key === 'Escape' && viewDialog.open) closeViewer();
      if (event.key === 'Escape' && confirmDialog.open) closeConfirm();
    });

    composeDialog?.addEventListener('click', (event) => {
      const rect = composeDialog.getBoundingClientRect();
      const inside = rect.top <= event.clientY && event.clientY <= rect.top + rect.height && rect.left <= event.clientX && event.clientX <= rect.left + rect.width;
      if (!inside) closeComposer();
    });

    refreshCaptcha();
    syncAuthUI();
    render();
