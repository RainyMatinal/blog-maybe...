---
// 中文: 站点页脚组件，展示 RainyMatinal 签名、站点标语和全站签名动画运行时。
// EN: Site footer component that renders the RainyMatinal signature, slogans, and the shared signature animation runtime.
import Signature from "../visual/Signature.astro";
---

<footer class="hybrid-footer" data-signature-version="rainy-signature-v20260701-5">
  <div class="footer-signature" aria-label="RainyMatinal 签名动画">
    <div class="signature-svg-wrapper">
      <Signature id="footer-rainy-signature" />
    </div>
    <div class="slogan-text">
      <p class="slogan-jp">桜の花の落ちる速さは秒速5センチメートル</p>
      <p class="slogan-cn">我该如何与你重逢</p>
    </div>
  </div>
  <div class="transmission-line">
    <span class="transmission-text">END OF TRANSMISSION</span>
  </div>
  <div class="footer-meta">
    <div class="copyright">
      <span class="copyright-main">&copy; 2026 <strong>RainyMatinal 苦难摇篮</strong></span>
      <span class="divider">·</span>
      <span class="rights-text">ALL RIGHTS RESERVED</span>
    </div>
    <a href="/blog/" class="rss-link">
      <span class="signal-indicator" aria-hidden="true"></span>
      <span class="rss-text">RSS SIGNAL</span>
    </a>
  </div>
</footer>
<script is:inline>
  (() => {
    const VERSION = "rainy-signature-v20260701-5";
    const LOOP_MS = 8000;

    const maskFrames = (index) => {
      const start = 0.035 + index * 0.055;
      const visible = Math.min(start + 0.015, 0.44);
      const drawn = Math.min(start + 0.22, 0.68);

      return [
        { offset: 0, opacity: 0, strokeDashoffset: 1 },
        { offset: start, opacity: 0, strokeDashoffset: 1 },
        { offset: visible, opacity: 1, strokeDashoffset: 1 },
        { offset: drawn, opacity: 1, strokeDashoffset: 0 },
        { offset: 0.84, opacity: 1, strokeDashoffset: 0 },
        { offset: 0.965, opacity: 0, strokeDashoffset: 1 },
        { offset: 1, opacity: 0, strokeDashoffset: 1 },
      ];
    };

    const inkFrames = [
      { offset: 0, opacity: 1 },
      { offset: 0.84, opacity: 1 },
      { offset: 0.965, opacity: 0 },
      { offset: 1, opacity: 1 },
    ];

    const lineFrames = [
      { offset: 0, opacity: 0, strokeDashoffset: 1 },
      { offset: 0.48, opacity: 0, strokeDashoffset: 1 },
      { offset: 0.56, opacity: 1, strokeDashoffset: 1 },
      { offset: 0.72, opacity: 1, strokeDashoffset: 0 },
      { offset: 0.84, opacity: 1, strokeDashoffset: 0 },
      { offset: 0.965, opacity: 0, strokeDashoffset: 1 },
      { offset: 1, opacity: 0, strokeDashoffset: 1 },
    ];

    const cancelAnimations = (node) => {
      node?.getAnimations?.().forEach((animation) => animation.cancel());
    };

    const prepareSignature = (signature) => {
      const ink = signature.querySelector(".sig-ink");
      const ghost = signature.querySelector(".sig-ghost");
      const line = signature.querySelector(".sig-underline");
      const strokes = Array.from(signature.querySelectorAll(".sig-mask-stroke"));
      if (!ink || !line || strokes.length === 0) return null;

      signature.dataset.signatureVersion = VERSION;
      signature.dataset.signatureReplayId = VERSION + "-" + Date.now() + "-" + Math.random().toString(36).slice(2);

      ink.style.fill = "currentColor";
      ink.style.stroke = "none";
      ink.style.opacity = "1";
      ink.style.animation = "none";

      if (ghost) {
        ghost.style.fill = "none";
        ghost.style.stroke = "currentColor";
        ghost.style.strokeWidth = "1";
        ghost.style.opacity = "0.08";
        ghost.style.animation = "none";
      }

      strokes.forEach((stroke) => {
        stroke.style.fill = "none";
        stroke.style.stroke = "#fff";
        stroke.style.strokeWidth = "42";
        stroke.style.strokeLinecap = "round";
        stroke.style.strokeLinejoin = "round";
        stroke.style.strokeDasharray = "1";
        stroke.style.strokeDashoffset = "1";
        stroke.style.opacity = "0";
        stroke.style.animation = "none";
      });

      line.style.fill = "none";
      line.style.stroke = "currentColor";
      line.style.strokeWidth = "4";
      line.style.strokeLinecap = "round";
      line.style.strokeDasharray = "1";
      line.style.strokeDashoffset = "1";
      line.style.opacity = "0";
      line.style.animation = "none";

      return { ink, ghost, line, strokes };
    };

    const replaySignature = () => {
      const signatures = document.querySelectorAll(".rainy-signature");
      signatures.forEach((signature) => {
        const parts = prepareSignature(signature);
        if (!parts) return;

        const animatedParts = [parts.ink, parts.ghost, parts.line, ...parts.strokes].filter(Boolean);
        animatedParts.forEach((part) => {
          cancelAnimations(part);
          part.style.animation = "none";
        });

        signature.getBoundingClientRect();

        requestAnimationFrame(() => {
          parts.ink.style.animation = "";
          parts.line.style.animation = "";
          parts.strokes.forEach((stroke) => {
            stroke.style.animation = "";
          });

          if (typeof parts.ink.animate === "function") {
            cancelAnimations(parts.ink);
            cancelAnimations(parts.line);
            parts.strokes.forEach(cancelAnimations);

            parts.ink.animate(inkFrames, {
              duration: LOOP_MS,
              iterations: Infinity,
              easing: "linear",
              fill: "both",
            });

            parts.strokes.forEach((stroke, index) => {
              stroke.animate(maskFrames(index), {
                duration: LOOP_MS,
                iterations: Infinity,
                easing: "cubic-bezier(0.33, 0, 0.18, 1)",
                fill: "both",
              });
            });

            parts.line.animate(lineFrames, {
              duration: LOOP_MS,
              iterations: Infinity,
              easing: "cubic-bezier(0.33, 0, 0.18, 1)",
              fill: "both",
            });
          }
        });
      });
    };

    const scheduleReplay = () => window.setTimeout(replaySignature, 32);

    if (!window.__rainySignatureRuntime || window.__rainySignatureRuntime.version !== VERSION) {
      window.__rainySignatureRuntime = { version: VERSION, replay: scheduleReplay };
      window.addEventListener("pageshow", scheduleReplay);
      document.addEventListener("astro:page-load", scheduleReplay);
      document.addEventListener("visibilitychange", () => {
        if (document.visibilityState === "visible") scheduleReplay();
      });
    } else {
      window.__rainySignatureRuntime.replay = scheduleReplay;
    }

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", scheduleReplay, { once: true });
    } else {
      scheduleReplay();
    }
  })();
</script>

<style is:inline>
  .rainy-signature {
    color: currentColor;
  }

  .rainy-signature text,
  .rainy-signature .sig-ink,
  .rainy-signature .sig-ghost {
    animation: none !important;
    stroke-dasharray: none !important;
    stroke-dashoffset: 0 !important;
  }

  .rainy-signature .sig-ink {
    fill: currentColor;
    opacity: 1;
    stroke: none;
  }

  .rainy-signature .sig-ghost {
    fill: none;
    opacity: 0.08;
    stroke: currentColor;
    stroke-width: 1;
  }

  .rainy-signature .sig-mask-stroke {
    fill: none;
    opacity: 0;
    stroke: #fff;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 42;
    stroke-dasharray: 1;
    stroke-dashoffset: 1;
    animation: rainy-signature-mask-write-v20260701-5 8000ms linear infinite both !important;
  }

  .rainy-signature .sig-underline {
    opacity: 0;
    fill: none;
    stroke: currentColor;
    stroke-width: 4;
    stroke-linecap: round;
    stroke-dasharray: 1;
    stroke-dashoffset: 1;
    animation: rainy-signature-line-v20260701-5 8000ms linear infinite both !important;
  }

  @keyframes rainy-signature-mask-write-v20260701-5 {
    0%,
    4% {
      opacity: 0;
      stroke-dashoffset: 1;
    }
    14% {
      opacity: 1;
      stroke-dashoffset: 1;
    }
    56%,
    84% {
      opacity: 1;
      stroke-dashoffset: 0;
    }
    96.5%,
    100% {
      opacity: 0;
      stroke-dashoffset: 1;
    }
  }

  @keyframes rainy-signature-line-v20260701-5 {
    0%,
    48% {
      opacity: 0;
      stroke-dashoffset: 1;
    }
    56% {
      opacity: 1;
      stroke-dashoffset: 1;
    }
    72%,
    84% {
      opacity: 1;
      stroke-dashoffset: 0;
    }
    96.5%,
    100% {
      opacity: 0;
      stroke-dashoffset: 1;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .rainy-signature .sig-mask-stroke,
    .rainy-signature .sig-underline {
      animation-duration: 8000ms !important;
      animation-iteration-count: infinite !important;
      animation-play-state: running !important;
    }
  }
</style>