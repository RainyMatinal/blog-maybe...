---

<button class="theme-toggle" type="button" aria-label="Toggle color theme" title="Toggle color theme" data-theme-toggle>
  <svg class="sun" viewBox="0 0 24 24" aria-hidden="true">
    <path d="M12 4V2m0 20v-2m8-8h2M2 12h2m13.66-5.66 1.42-1.42M4.92 19.08l1.42-1.42m0-11.32L4.92 4.92m14.16 14.16-1.42-1.42" />
    <circle cx="12" cy="12" r="4" />
  </svg>
  <svg class="moon" viewBox="0 0 24 24" aria-hidden="true">
    <path d="M20 15.6A8.5 8.5 0 0 1 8.4 4 8.5 8.5 0 1 0 20 15.6Z" />
  </svg>
</button>

<script>
  const button = document.querySelector<HTMLButtonElement>('[data-theme-toggle]');
  const getTheme = () => document.documentElement.dataset.theme || (matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
  const sync = () => {
    if (button) button.dataset.currentTheme = getTheme();
  };

  button?.addEventListener('click', () => {
    const next = getTheme() === 'dark' ? 'light' : 'dark';
    document.documentElement.dataset.theme = next;
    localStorage.setItem('theme', next);
    sync();
  });

  sync();
</script>

<style>
  .theme-toggle {
    display: inline-grid;
    width: 36px;
    height: 36px;
    place-items: center;
    border: 2px solid var(--color-border);
    border-radius: 45% 55% 48% 52% / 50% 44% 56% 50%;
    background: var(--color-surface-strong);
    box-shadow: var(--shadow-doodle-small);
    color: #171411;
    cursor: pointer;
  }

  .theme-toggle:hover {
    background: var(--color-accent);
    box-shadow: 2px 2px 0 var(--color-shadow);
    color: #fffdf3;
    transform: translate(2px, 2px) rotate(-5deg);
  }

  .theme-toggle svg {
    width: 17px;
    height: 17px;
    fill: none;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 1.7;
  }

  .theme-toggle .moon,
  .theme-toggle[data-current-theme='dark'] .sun {
    display: none;
  }

  .theme-toggle[data-current-theme='dark'] .moon {
    display: block;
  }
</style>
