---
import Cover from '@/components/Cover.astro';
import TagPill from '@/components/TagPill.astro';
import { formatDate, getPostSlug, type BlogPost } from '@/lib/posts';
import { localizedPath } from '@/i18n/utils';

interface Props {
  post: BlogPost;
}

const { post } = Astro.props;
const slug = getPostSlug(post);
const href = localizedPath(post.data.lang, `/blog/${slug}`);
const cover = post.data.cover ?? '/images/og-image.svg';
---

<article class="post-card" data-reveal>
  <a href={href} aria-label={post.data.title}>
    <Cover src={cover} alt={post.data.title} />
  </a>
  <div class="card-body">
    <div class="ui-font card-meta">{formatDate(post.data.pubDate, post.data.lang)}</div>
    <h3><a href={href}>{post.data.title}</a></h3>
    <p>{post.data.description}</p>
    <div class="card-tags">
      {post.data.tags.map((tag) => <TagPill tag={tag} />)}
    </div>
  </div>
</article>

<style>
  .post-card {
    position: relative;
    display: grid;
    gap: 16px;
    padding: 14px;
    border: var(--border-doodle);
    border-radius: 28px 18px 32px 16px / 18px 30px 16px 26px;
    background: var(--color-surface);
    box-shadow: var(--shadow-doodle);
    transform: rotate(-0.8deg);
  }

  .post-card:nth-child(2n) {
    transform: rotate(1deg);
  }

  .post-card:nth-child(3n) {
    transform: rotate(-1.5deg);
  }

  .post-card:hover {
    box-shadow: 3px 3px 0 var(--color-shadow);
    transform: translate(4px, 4px) rotate(0deg);
  }

  .post-card::before {
    position: absolute;
    top: -13px;
    right: 28px;
    width: 52px;
    height: 22px;
    border: 2px solid var(--color-border);
    border-radius: 10px 7px 12px 8px;
    background: color-mix(in srgb, var(--color-accent-2) 72%, #fffdf3);
    content: '';
    transform: rotate(5deg);
  }

  .card-body {
    display: grid;
    gap: 8px;
  }

  .card-meta {
    width: fit-content;
    border-bottom: 4px solid var(--color-surface-strong);
    color: var(--color-muted);
    font-size: 17px;
    font-weight: 700;
  }

  h3 {
    margin: 0;
    font-family: 'Gaegu', 'DM Sans', sans-serif;
    font-size: 26px;
    font-weight: 700;
    line-height: 1.35;
    letter-spacing: 0;
  }

  h3 a:hover {
    color: var(--color-accent);
  }

  p {
    display: -webkit-box;
    margin: 0;
    overflow: hidden;
    color: var(--color-muted);
    font-size: 16px;
    line-height: 1.65;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
  }

  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 8px;
  }
</style>
