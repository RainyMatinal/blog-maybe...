---
import LangSwitcher from '@/components/LangSwitcher.astro';
import ThemeToggle from '@/components/ThemeToggle.astro';
import type { Lang } from '@/i18n/ui';
import { localizedPath, useTranslations } from '@/i18n/utils';

interface Props {
  lang: Lang;
  switchTo?: string;
}

const { lang, switchTo } = Astro.props;
const t = useTranslations(lang);
const links = [
  { href: localizedPath(lang, '/'), label: t('nav.home') },
  { href: localizedPath(lang, '/blog'), label: t('nav.blog') },
  { href: localizedPath(lang, '/about'), label: t('nav.about') }
];
---

<header class="site-nav">
  <nav class="site-shell nav-inner" aria-label="Primary">
    <a class="ui-font brand" href={localizedPath(lang, '/')}>{lang === 'zh' ? '生活与设计' : 'Life & Design'}</a>
    <div class="nav-links">
      {links.map((link) => <a class="ui-font" href={link.href}>{link.label}</a>)}
    </div>
    <div class="nav-actions">
      <ThemeToggle />
      <LangSwitcher lang={lang} to={switchTo} />
    </div>
  </nav>
</header>

<style>
  .site-nav {
    position: sticky;
    top: 0;
    z-index: 20;
    border-bottom: var(--border-doodle);
    background: color-mix(in srgb, var(--color-surface) 88%, transparent);
    box-shadow: 0 5px 0 var(--color-shadow);
    backdrop-filter: blur(10px);
  }

  .nav-inner {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    min-height: 72px;
    align-items: center;
    gap: 24px;
  }

  .brand {
    position: relative;
    width: fit-content;
    color: var(--color-text);
    font-size: 22px;
    font-weight: 700;
  }

  .brand::after {
    position: absolute;
    right: -8px;
    bottom: 1px;
    left: -8px;
    z-index: -1;
    height: 10px;
    border-radius: 50%;
    background: var(--color-surface-strong);
    content: '';
    transform: rotate(-2deg);
  }

  .nav-links,
  .nav-actions {
    display: flex;
    align-items: center;
    gap: 18px;
  }

  .nav-links {
    justify-content: center;
  }

  .nav-links a {
    border: 2px solid transparent;
    border-radius: 18px 13px 20px 12px / 12px 18px 10px 16px;
    color: var(--color-text);
    font-size: 17px;
    font-weight: 700;
    padding: 2px 10px;
  }

  .nav-links a:hover {
    border-color: var(--color-border);
    background: var(--color-accent-bg);
    color: var(--color-accent);
    transform: rotate(-2deg) translateY(-1px);
  }

  .nav-actions {
    justify-content: flex-end;
    gap: 10px;
  }

  @media (max-width: 680px) {
    .nav-inner {
      grid-template-columns: 1fr auto;
      min-height: 64px;
    }

    .nav-links {
      grid-column: 1 / -1;
      justify-content: flex-start;
      padding-bottom: 14px;
      overflow-x: auto;
    }
  }
</style>
