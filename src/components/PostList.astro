---
import TagPill from '@/components/TagPill.astro';
import { formatDate, getAllTags, getPostSlug, type BlogPost } from '@/lib/posts';
import { localizedPath } from '@/i18n/utils';
import type { Lang } from '@/i18n/ui';

interface Props {
  posts: BlogPost[];
  lang: Lang;
}

const { posts, lang } = Astro.props;
const tags = getAllTags(posts);
---

<section class="post-list" data-post-list>
  <div class="tag-row" aria-label={lang === 'zh' ? '标签筛选' : 'Filter by tag'}>
    <button class="ui-font tag-all active" type="button" data-tag-filter="all">{lang === 'zh' ? '全部' : 'All'}</button>
    {tags.map((tag) => <TagPill tag={tag} asButton />)}
  </div>
  <div class="entries">
    {posts.map((post) => {
      const slug = getPostSlug(post);
      return (
        <article class="entry" data-post-item data-tags={post.data.tags.join('|')}>
          <a href={localizedPath(lang, `/blog/${slug}`)}>
            <span class="ui-font date">{formatDate(post.data.pubDate, lang)}</span>
            <h2>{post.data.title}</h2>
            <p>{post.data.description}</p>
            <span class="entry-tags ui-font">{post.data.tags.join(' / ')}</span>
          </a>
        </article>
      );
    })}
  </div>
</section>

<script>
  const root = document.querySelector<HTMLElement>('[data-post-list]');
  const buttons = root ? [...root.querySelectorAll<HTMLButtonElement>('[data-tag-filter]')] : [];
  const items = root ? [...root.querySelectorAll<HTMLElement>('[data-post-item]')] : [];

  buttons.forEach((button) => {
    button.addEventListener('click', () => {
      const tag = button.dataset.tagFilter || 'all';
      buttons.forEach((item) => item.classList.toggle('active', item === button));
      items.forEach((item) => {
        const tags = (item.dataset.tags || '').split('|');
        item.hidden = tag !== 'all' && !tags.includes(tag);
      });
    });
  });
</script>

<style>
  .post-list {
    display: grid;
    gap: 34px;
  }

  .tag-row {
    display: flex;
    gap: 10px;
    overflow-x: auto;
    padding: 0 0 10px 3px;
  }

  .tag-all {
    display: inline-flex;
    min-height: 34px;
    align-items: center;
    padding: 0 13px;
    border: 2px solid var(--color-border);
    border-radius: 18px 13px 20px 12px / 12px 18px 10px 16px;
    background: var(--color-surface);
    box-shadow: 3px 3px 0 var(--color-shadow);
    color: var(--color-text);
    cursor: pointer;
    font-size: 16px;
    font-weight: 700;
    line-height: 1;
    white-space: nowrap;
    transform: rotate(1deg);
  }

  .tag-all.active,
  .tag-all:hover {
    border-color: var(--color-accent);
    background: var(--color-surface-strong);
    box-shadow: 1px 1px 0 var(--color-shadow);
    color: #171411;
    transform: translate(2px, 2px) rotate(-2deg);
  }

  .entries {
    display: grid;
    gap: 16px;
  }

  .entry {
    border: var(--border-doodle);
    border-radius: 24px 16px 28px 18px / 18px 26px 15px 24px;
    background: var(--color-surface);
    box-shadow: var(--shadow-doodle-small);
    transform: rotate(-0.4deg);
  }

  .entry:nth-child(2n) {
    transform: rotate(0.5deg);
  }

  .entry a {
    display: grid;
    grid-template-columns: 120px 1fr 1.5fr 150px;
    gap: 24px;
    padding: 22px 18px;
    align-items: baseline;
  }

  .date,
  .entry-tags {
    color: var(--color-muted);
    font-size: 16px;
    font-weight: 700;
    line-height: 1.5;
  }

  h2 {
    margin: 0;
    font-family: 'Gaegu', 'DM Sans', sans-serif;
    font-size: 26px;
    font-weight: 700;
    line-height: 1.35;
    letter-spacing: 0;
  }

  p {
    overflow: hidden;
    margin: 0;
    color: var(--color-muted);
    font-size: 16px;
    line-height: 1.7;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .entry:hover h2 {
    color: var(--color-accent);
  }

  .entry:hover {
    box-shadow: 2px 2px 0 var(--color-shadow);
    transform: translate(3px, 3px) rotate(0deg);
  }

  @media (max-width: 840px) {
    .entry a {
      grid-template-columns: 1fr;
      gap: 8px;
    }
  }
</style>
