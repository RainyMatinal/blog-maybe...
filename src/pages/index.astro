---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";

const posts = (await getCollection("blog", ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const formatDate = (date: Date) =>
  new Intl.DateTimeFormat("zh-CN", {
    year: "numeric",
    month: "2-digit",
    day: "2-digit",
  }).format(date);

const postHref = (id: string) => `/blog/${id.replace(/\.mdx?$/, "")}`;

const categories = [
  {
    code: "ARCH LOG",
    title: "Arch Logs",
    text: "安装、桌面环境、输入法、pacman、日常排障。",
    accent: "var(--cat-arch)",
    href: "/blog",
  },
  {
    code: "GIT FIELD",
    title: "Git Field Notes",
    text: "SSH key、remote、push 失败、分支与提交记录。",
    accent: "var(--cat-git)",
    href: "/blog",
  },
  {
    code: "C / ASTRO",
    title: "C & Frontend Lab",
    text: "C 语言、Astro、HTML、CSS、组件和构建日志。",
    accent: "var(--cat-code)",
    href: "/blog",
  },
  {
    code: "NETWORK",
    title: "Network Engineering",
    text: "VLAN、STP、DHCP、H3C CLI 与现场排障。",
    accent: "var(--cat-network)",
    href: "/blog",
  },
  {
    code: "EXAM ROAD",
    title: "Exam Roadmap",
    text: "自考、考研、长期学习计划和阶段复盘。",
    accent: "var(--cat-exam)",
    href: "/blog",
  },
  {
    code: "AERO WEB",
    title: "Aero Archive",
    text: "Frutiger Aero、旧网页、个人审美和随笔。",
    accent: "var(--cat-aero)",
    href: "/blog",
  },
];

const techArchive = [
  ["Arch Linux", ["安装记录", "桌面环境", "中文输入法", "开发工具链"]],
  ["Git / GitHub", ["SSH 配置", "remote 检查", "提交习惯", "仓库同步"]],
  ["Network Engineering", ["VLAN", "Access / Trunk", "DHCP", "H3C CLI"]],
  ["Frontend Lab", ["Astro", "CSS tokens", "Content collections", "静态构建"]],
];
---

<BaseLayout
  title="RainyMatinal Network Archive"
  description="一个蓝绿色玻璃感的个人技术档案馆，记录 Linux、Git、前端、网络工程与长期学习。"
>
  <div class="home-page">
    <section class="hero-grid" aria-labelledby="home-title">
      <article class="hero-window window-card">
        <div class="window-titlebar">
          <span class="window-dot dot-red" aria-hidden="true"></span>
          <span class="window-dot dot-yellow" aria-hidden="true"></span>
          <span class="window-dot dot-green" aria-hidden="true"></span>
          <span>network-archive://home/identity</span>
        </div>

        <div class="hero-body">
          <div class="hero-copy">
            <p class="section-kicker">Personal Technical Log / Since 2026</p>
            <h1 id="home-title">RainyMatinal Network Archive</h1>
            <p class="hero-intro">
              在蓝绿色旧互联网回声里，记录 Arch Linux、Git、C、Astro、网络工程和长期学习的个人技术档案馆。
            </p>
            <div class="hero-actions" aria-label="首页快捷入口">
              <a class="old-button" href="#recent-posts">读取最近文章</a>
              <a class="old-button secondary" href="#tech-archive">打开技术档案</a>
            </div>
          </div>

          <div class="hero-orbit" aria-label="技术主题拓扑图">
            <span class="orbit-node node-core">RM</span>
            <span class="orbit-node node-arch">Arch</span>
            <span class="orbit-node node-git">Git</span>
            <span class="orbit-node node-net">VLAN</span>
            <span class="orbit-node node-code">Astro</span>
            <span class="orbit-line line-a"></span>
            <span class="orbit-line line-b"></span>
            <span class="orbit-line line-c"></span>
          </div>
        </div>
      </article>

      <aside class="status-window window-card" aria-label="当前系统状态">
        <div class="window-titlebar">
          <span class="window-dot dot-green" aria-hidden="true"></span>
          <span>system-status.ini</span>
        </div>
        <dl class="status-list">
          <div>
            <dt><span class="status-light active"></span> OS</dt>
            <dd>Arch Linux</dd>
          </div>
          <div>
            <dt><span class="status-light status-blue"></span> Learning</dt>
            <dd>C / Astro / Git</dd>
          </div>
          <div>
            <dt><span class="status-light status-yellow"></span> Network</dt>
            <dd>VLAN / STP / DHCP / H3C</dd>
          </div>
          <div>
            <dt><span class="status-light status-aero"></span> Mood</dt>
            <dd>Frutiger Aero, 2000s Web</dd>
          </div>
        </dl>
      </aside>
    </section>

    <section class="one-line window-card" aria-label="一句话介绍">
      <span class="one-line-label">ONE LINE</span>
      <p>公开学习，像旧互联网一样归档；把每一次配置、报错、复盘和灵感都留在这里。</p>
    </section>

    <section class="home-section" id="recent-posts" aria-labelledby="recent-title">
      <div class="section-heading">
        <p class="section-kicker">Latest Log Stream</p>
        <h2 id="recent-title">最近文章</h2>
      </div>

      <div class="log-window window-card">
        <div class="window-titlebar">
          <span class="window-dot dot-green" aria-hidden="true"></span>
          <span>latest-posts.log</span>
        </div>
        <div class="post-stream">
          {posts.map((post) => (
            <article class="post-row">
              <div class="post-date">{formatDate(post.data.pubDate)}</div>
              <div class="post-body">
                <p class="post-category">[{post.data.category}]</p>
                <h3>
                  <a href={postHref(post.id)}>{post.data.title}</a>
                </h3>
                <p>{post.data.description}</p>
                <ul class="post-tags" aria-label={`${post.data.title} 标签`}>
                  {post.data.tags.slice(0, 4).map((tag) => (
                    <li>#{tag}</li>
                  ))}
                </ul>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="home-section" aria-labelledby="category-title">
      <div class="section-heading">
        <p class="section-kicker">Archive Cabinet</p>
        <h2 id="category-title">分类入口</h2>
      </div>

      <div class="category-grid">
        {categories.map((category) => (
          <a class="category-card" href={category.href} style={`--accent: ${category.accent}`}>
            <span class="category-code">[{category.code}]</span>
            <strong>{category.title}</strong>
            <span>{category.text}</span>
          </a>
        ))}
      </div>
    </section>

    <section class="home-section archive-map" id="tech-archive" aria-labelledby="archive-title">
      <div class="section-heading">
        <p class="section-kicker">Technical Archive</p>
        <h2 id="archive-title">技术档案区</h2>
      </div>

      <div class="archive-map-grid">
        <div class="file-tree window-card">
          <div class="window-titlebar">
            <span class="window-dot dot-yellow" aria-hidden="true"></span>
            <span>learning-map.tree</span>
          </div>
          <div class="tree-body">
            {techArchive.map(([group, items]) => (
              <div class="tree-group">
                <strong>{group}</strong>
                <ul>
                  {items.map((item) => (
                    <li>{item}</li>
                  ))}
                </ul>
              </div>
            ))}
          </div>
        </div>

        <div class="terminal-widget window-card" aria-label="终端窗口风格小组件">
          <div class="terminal-titlebar">
            <span class="window-dot dot-red" aria-hidden="true"></span>
            <span class="window-dot dot-yellow" aria-hidden="true"></span>
            <span class="window-dot dot-green" aria-hidden="true"></span>
            <span>terminal - archive sync</span>
          </div>
          <pre aria-label="终端输出"><code>$ git status --short
 M src/pages/index.astro
$ astro check-archive --latest
 [ok] Arch Linux 安装记录
 [ok] GitHub SSH 配置笔记
 [ok] H3C VLAN 基础笔记
$ display vlan brief
 VLAN 1020  learning-lab  active
 VLAN 1030  aero-archive  active</code></pre>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .home-page {
    display: grid;
    gap: var(--space-8);
  }

  .hero-grid {
    display: grid;
    gap: var(--space-5);
    grid-template-columns: minmax(0, 1fr) minmax(15rem, 18rem);
  }

  .hero-window,
  .status-window,
  .log-window,
  .file-tree,
  .terminal-widget {
    overflow: hidden;
  }

  .hero-body {
    display: grid;
    gap: clamp(1.5rem, 4vw, 3rem);
    grid-template-columns: minmax(0, 1fr) minmax(13rem, 17rem);
    min-height: 27rem;
    padding: clamp(1.5rem, 5vw, 4rem);
    position: relative;
  }

  .hero-body::before {
    background:
      radial-gradient(circle at 30% 26%, rgba(111, 255, 233, 0.42), transparent 0.7rem),
      radial-gradient(circle at 64% 14%, rgba(94, 200, 255, 0.32), transparent 0.55rem),
      linear-gradient(135deg, rgba(94, 200, 255, 0.2), rgba(255, 255, 255, 0));
    border-radius: 999px;
    content: "";
    filter: blur(0.3px);
    height: 12rem;
    pointer-events: none;
    position: absolute;
    right: 18%;
    top: 10%;
    width: 12rem;
  }

  .hero-copy {
    align-self: center;
    position: relative;
    z-index: 1;
  }

  .hero-copy h1 {
    font-size: clamp(2.3rem, 5vw, 4.15rem);
    max-width: 12ch;
  }

  .hero-intro {
    color: var(--text-muted);
    font-size: clamp(1.05rem, 2vw, 1.22rem);
    line-height: 1.9;
    max-width: 42rem;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-top: var(--space-6);
  }

  .old-button {
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.9), rgba(111, 255, 233, 0.2));
    border: 1px solid rgba(94, 200, 255, 0.58);
    border-radius: var(--radius-sm);
    box-shadow: var(--shadow-inset), 0 8px 18px rgba(47, 128, 237, 0.16);
    color: #14506b;
    font-family: var(--font-mono);
    font-size: 0.86rem;
    padding: 0.72rem 0.95rem;
    text-decoration: none;
  }

  .old-button.secondary {
    background: rgba(255, 255, 255, 0.54);
  }

  .hero-orbit {
    align-self: center;
    aspect-ratio: 1;
    background:
      linear-gradient(90deg, rgba(47, 128, 237, 0.1) 1px, transparent 1px),
      linear-gradient(rgba(47, 128, 237, 0.1) 1px, transparent 1px),
      radial-gradient(circle, rgba(111, 255, 233, 0.28), rgba(94, 200, 255, 0.1) 46%, rgba(255, 255, 255, 0.38));
    background-size: 24px 24px, 24px 24px, auto;
    border: 1px solid rgba(255, 255, 255, 0.78);
    border-radius: 50%;
    box-shadow: var(--shadow-glass), inset 0 0 36px rgba(255, 255, 255, 0.82);
    min-width: 13rem;
    position: relative;
  }

  .orbit-node {
    align-items: center;
    background: rgba(255, 255, 255, 0.78);
    border: 1px solid rgba(94, 200, 255, 0.58);
    border-radius: var(--radius-pill);
    box-shadow: 0 10px 20px rgba(31, 102, 148, 0.15);
    color: #14506b;
    display: inline-flex;
    font-family: var(--font-mono);
    font-size: 0.74rem;
    justify-content: center;
    min-width: 3.2rem;
    padding: 0.44rem 0.58rem;
    position: absolute;
    z-index: 2;
  }

  .node-core {
    background: linear-gradient(145deg, var(--color-system-blue), var(--color-aero-cyan));
    color: var(--text-invert);
    font-weight: 800;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
  }

  .node-arch {
    left: 12%;
    top: 24%;
  }

  .node-git {
    right: 10%;
    top: 18%;
  }

  .node-net {
    bottom: 18%;
    right: 14%;
  }

  .node-code {
    bottom: 18%;
    left: 12%;
  }

  .orbit-line {
    background: rgba(47, 128, 237, 0.22);
    height: 1px;
    left: 20%;
    position: absolute;
    top: 50%;
    transform-origin: center;
    width: 60%;
  }

  .line-a {
    transform: rotate(22deg);
  }

  .line-b {
    transform: rotate(-28deg);
  }

  .line-c {
    transform: rotate(90deg);
  }

  .status-list {
    display: grid;
    gap: var(--space-4);
    margin: 0;
    padding: var(--space-5);
  }

  .status-list div {
    border-left: 3px solid rgba(94, 200, 255, 0.5);
    padding-left: var(--space-3);
  }

  .status-list dt {
    align-items: center;
    color: var(--text-soft);
    display: flex;
    font-family: var(--font-mono);
    font-size: 0.74rem;
    gap: var(--space-2);
    text-transform: uppercase;
  }

  .status-list dd {
    color: var(--text-main);
    font-weight: 700;
    margin: var(--space-1) 0 0;
  }

  .status-blue {
    background: var(--color-aero-blue);
    color: var(--color-aero-blue);
  }

  .status-yellow {
    background: var(--color-warning-amber);
    color: var(--color-warning-amber);
  }

  .status-aero {
    background: var(--color-xp-grass);
    color: var(--color-xp-grass);
  }

  .one-line {
    align-items: center;
    display: grid;
    gap: var(--space-4);
    grid-template-columns: auto minmax(0, 1fr);
    padding: var(--space-5);
  }

  .one-line-label {
    background: rgba(16, 36, 62, 0.92);
    border-radius: var(--radius-sm);
    color: var(--color-aero-cyan);
    font-family: var(--font-mono);
    font-size: 0.76rem;
    padding: 0.5rem 0.65rem;
  }

  .one-line p {
    color: var(--text-main);
    font-size: clamp(1rem, 2vw, 1.2rem);
    margin: 0;
  }

  .home-section {
    display: grid;
    gap: var(--space-5);
  }

  .section-heading h2 {
    margin-bottom: 0;
  }

  .post-stream {
    display: grid;
  }

  .post-row {
    display: grid;
    gap: var(--space-4);
    grid-template-columns: 8.6rem minmax(0, 1fr);
    padding: var(--space-5);
  }

  .post-row + .post-row {
    border-top: 1px solid rgba(47, 128, 237, 0.14);
  }

  .post-date,
  .post-category,
  .post-tags {
    font-family: var(--font-mono);
  }

  .post-date {
    color: var(--text-soft);
    font-size: 0.82rem;
  }

  .post-category {
    color: var(--color-system-blue);
    font-size: 0.76rem;
    font-weight: 700;
    margin-bottom: var(--space-2);
  }

  .post-body h3 {
    font-family: var(--font-title);
    font-size: clamp(1.2rem, 2vw, 1.55rem);
    margin-bottom: var(--space-2);
  }

  .post-body h3 a {
    color: var(--text-main);
    text-decoration: none;
  }

  .post-body p {
    color: var(--text-muted);
  }

  .post-tags {
    color: #14506b;
    display: flex;
    flex-wrap: wrap;
    font-size: 0.76rem;
    gap: var(--space-2);
    list-style: none;
    margin: var(--space-3) 0 0;
    padding: 0;
  }

  .post-tags li {
    background: rgba(111, 255, 233, 0.18);
    border: 1px solid rgba(94, 200, 255, 0.34);
    border-radius: var(--radius-pill);
    padding: 0.32rem 0.55rem;
  }

  .category-grid {
    display: grid;
    gap: var(--space-4);
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .category-card {
    background: var(--bg-glass);
    backdrop-filter: blur(18px);
    border: 1px solid var(--border-glass);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-glass), var(--shadow-inset);
    color: var(--text-main);
    display: grid;
    gap: var(--space-2);
    min-height: 12rem;
    padding: var(--space-5);
    position: relative;
    text-decoration: none;
    transition: border-color 180ms ease, box-shadow 180ms ease, transform 180ms ease;
  }

  .category-card::before {
    background: var(--accent);
    border-radius: var(--radius-pill);
    content: "";
    height: 0.3rem;
    inset: var(--space-4) var(--space-4) auto;
    position: absolute;
  }

  .category-card:hover {
    border-color: rgba(94, 200, 255, 0.8);
    box-shadow: 0 18px 42px rgba(31, 102, 148, 0.24);
    transform: translateY(-3px);
  }

  .category-code {
    color: var(--color-system-blue);
    font-family: var(--font-mono);
    font-size: 0.76rem;
    margin-top: var(--space-3);
  }

  .category-card strong {
    font-family: var(--font-title);
    font-size: 1.3rem;
  }

  .category-card span:last-child {
    color: var(--text-muted);
  }

  .archive-map-grid {
    display: grid;
    gap: var(--space-5);
    grid-template-columns: minmax(0, 1fr) minmax(18rem, 0.86fr);
  }

  .tree-body {
    display: grid;
    gap: var(--space-4);
    padding: var(--space-5);
  }

  .tree-group {
    border-left: 2px solid rgba(94, 200, 255, 0.42);
    padding-left: var(--space-4);
  }

  .tree-group strong {
    color: var(--text-main);
    font-family: var(--font-mono);
  }

  .tree-group ul {
    color: var(--text-muted);
    font-family: var(--font-mono);
    font-size: 0.88rem;
    list-style: none;
    margin: var(--space-2) 0 0;
    padding: 0;
  }

  .tree-group li::before {
    color: var(--color-aero-blue);
    content: "+-- ";
  }

  .terminal-widget {
    background: linear-gradient(180deg, var(--bg-code), var(--bg-terminal));
    border-color: rgba(94, 200, 255, 0.34);
    box-shadow: var(--shadow-window);
  }

  .terminal-titlebar {
    align-items: center;
    background: rgba(255, 255, 255, 0.08);
    border-bottom: 1px solid rgba(94, 200, 255, 0.22);
    color: rgba(245, 251, 255, 0.74);
    display: flex;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    gap: var(--space-2);
    min-height: 2.2rem;
    padding: 0 var(--space-4);
  }

  .terminal-widget pre {
    color: var(--text-invert);
    font-family: var(--font-mono);
    font-size: 0.88rem;
    line-height: 1.75;
    margin: 0;
    overflow-x: auto;
    padding: var(--space-5);
    white-space: pre-wrap;
  }

  .terminal-widget code {
    color: inherit;
  }

  @media (max-width: 980px) {
    .hero-grid,
    .hero-body,
    .archive-map-grid {
      grid-template-columns: 1fr;
    }

    .status-list {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .category-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .hero-body {
      min-height: auto;
    }
  }

  @media (max-width: 680px) {
    .home-page {
      gap: var(--space-7);
    }

    .hero-body {
      padding: var(--space-5);
    }

    .hero-orbit {
      min-width: 0;
      width: 100%;
    }

    .status-list,
    .category-grid,
    .one-line,
    .post-row {
      grid-template-columns: 1fr;
    }

    .post-row {
      padding: var(--space-4);
    }

    .category-card {
      min-height: auto;
    }
  }
</style>
