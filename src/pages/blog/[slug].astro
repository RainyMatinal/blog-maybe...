---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Cover from '@/components/Cover.astro';
import ReadingTime from '@/components/ReadingTime.astro';
import TOC from '@/components/TOC.astro';
import TagPill from '@/components/TagPill.astro';
import { formatDate, getPostSlug, getPosts, getTranslation, type BlogPost } from '@/lib/posts';
import { localizedPath } from '@/i18n/utils';

export async function getStaticPaths() {
  const posts = await getPosts('zh');
  return posts.map((post) => ({
    params: { slug: getPostSlug(post) },
    props: { post }
  }));
}

const post = Astro.props.post as BlogPost;
const posts = await getPosts('zh');
const index = posts.findIndex((entry) => entry.id === post.id);
const prevPost = posts[index + 1];
const nextPost = posts[index - 1];
const translation = await getTranslation(post, 'en');
const { Content, headings } = await post.render();
const switchTo = translation ? localizedPath('en', `/blog/${getPostSlug(translation)}`) : '/en/';
---

<BaseLayout lang="zh" title={post.data.title} description={post.data.description} image={post.data.cover} switchTo={switchTo}>
  <article>
    <header class="reading-width post-head">
      <nav class="breadcrumb ui-font" aria-label="面包屑">
        <a href="/">首页</a>
        <span>→</span>
        <a href="/blog">博客</a>
        <span>→</span>
        <span>{post.data.title}</span>
      </nav>
      <h1 class="ui-font">{post.data.title}</h1>
      <div class="tag-row">
        {post.data.tags.map((tag) => <TagPill tag={tag} />)}
      </div>
      <div class="meta ui-font">
        <span>发布于 {formatDate(post.data.pubDate, 'zh')}</span>
        <span>阅读 <ReadingTime text={post.body} lang="zh" /></span>
        <a href={switchTo}>EN</a>
      </div>
    </header>

    {post.data.cover && (
      <div class="reading-width cover-wrap">
        <Cover src={post.data.cover} alt={post.data.title} eager />
      </div>
    )}

    <div class="article-grid">
      <div class="article-prose">
        <Content />
      </div>
      <TOC headings={headings} title="目录" />
    </div>

    <footer class="reading-width post-footer">
      <div class="post-nav ui-font">
        <div>
          <span>上一篇</span>
          {prevPost ? <a href={localizedPath('zh', `/blog/${getPostSlug(prevPost)}`)}>{prevPost.data.title}</a> : <em>暂无</em>}
        </div>
        <div>
          <span>下一篇</span>
          {nextPost ? <a href={localizedPath('zh', `/blog/${getPostSlug(nextPost)}`)}>{nextPost.data.title}</a> : <em>暂无</em>}
        </div>
      </div>
      <div class="tag-cloud">
        {post.data.tags.map((tag) => <TagPill tag={tag} />)}
      </div>
    </footer>
  </article>
</BaseLayout>

<style>
  .post-head {
    position: relative;
    padding-top: 78px;
  }

  .breadcrumb,
  .meta {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    color: var(--color-text);
    font-size: 16px;
    font-weight: 700;
    line-height: 1.5;
  }

  .breadcrumb a,
  .meta span,
  .meta a {
    padding: 2px 8px;
    border: 2px solid var(--color-border);
    border-radius: 18px 12px 20px 13px / 12px 18px 10px 16px;
    background: var(--color-surface);
    box-shadow: 3px 3px 0 var(--color-shadow);
  }

  h1 {
    display: -webkit-box;
    overflow: hidden;
    margin: 24px 0 18px;
    font-family: 'ZCOOL KuaiLe', 'Noto Serif SC', serif;
    font-size: 56px;
    font-weight: 400;
    line-height: 1.08;
    letter-spacing: 0;
    text-shadow: 4px 4px 0 var(--color-surface-strong);
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 3;
  }

  .tag-row,
  .tag-cloud {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .meta {
    margin-top: 20px;
  }

  .meta a {
    color: var(--color-accent);
  }

  .cover-wrap {
    margin-top: 46px;
    transform: rotate(-1deg);
  }

  .article-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: 48px;
    margin-top: 56px;
  }

  .post-footer {
    margin-top: 72px;
    padding-top: 32px;
    border-top: 4px dashed var(--color-border);
  }

  .post-nav {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 24px;
    margin-bottom: 28px;
    font-size: 18px;
    font-weight: 700;
    line-height: 1.6;
  }

  .post-nav div {
    display: grid;
    gap: 6px;
    padding: 16px;
    border: var(--border-doodle);
    border-radius: 24px 14px 28px 16px / 15px 26px 14px 22px;
    background: var(--color-surface);
    box-shadow: var(--shadow-doodle-small);
  }

  .post-nav span,
  .post-nav em {
    color: var(--color-accent);
    font-style: normal;
  }

  @media (min-width: 1280px) {
    .article-grid {
      grid-template-columns: 1fr 220px;
      width: min(100% - 32px, 1180px);
      margin-inline: auto;
    }

    .article-prose {
      margin-left: auto;
      margin-right: 68px;
    }
  }

  @media (max-width: 640px) {
    h1 {
      font-size: 40px;
    }

    .post-nav {
      grid-template-columns: 1fr;
    }
  }
</style>
