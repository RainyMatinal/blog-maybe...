---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PostList from '@/components/PostList.astro';
import { getPosts } from '@/lib/posts';

const lang = 'zh';
const posts = await getPosts(lang);
---

<BaseLayout lang={lang} title="博客" description="生活随笔、设计思考、旅行记录与产品评测。">
  <section class="site-shell page-head">
    <p class="ui-font eyebrow">{posts.length} 篇文章</p>
    <h1 class="ui-font">博客</h1>
  </section>
  <section class="site-shell section-space">
    <PostList posts={posts} lang={lang} />
  </section>
</BaseLayout>

<style>
  .page-head {
    position: relative;
    padding-top: 88px;
  }

  .page-head::after {
    position: absolute;
    right: 10%;
    bottom: -22px;
    width: 150px;
    height: 34px;
    border: var(--border-doodle);
    border-radius: 50%;
    background: var(--color-surface-strong);
    box-shadow: var(--shadow-doodle-small);
    content: '';
    transform: rotate(-6deg);
  }

  .eyebrow {
    width: fit-content;
    margin: 0 0 12px;
    padding: 2px 12px;
    border: 2px solid var(--color-border);
    border-radius: 18px 12px 20px 13px / 12px 18px 10px 16px;
    background: var(--color-accent-2);
    box-shadow: var(--shadow-doodle-small);
    color: #fffdf3;
    font-size: 18px;
    font-weight: 700;
    transform: rotate(-2deg);
  }

  h1 {
    margin: 0;
    font-family: 'ZCOOL KuaiLe', 'Noto Serif SC', serif;
    font-size: 72px;
    font-weight: 400;
    line-height: 1.05;
    letter-spacing: 0;
    text-shadow: 4px 4px 0 var(--color-surface-strong);
  }

  @media (max-width: 640px) {
    h1 {
      font-size: 46px;
    }
  }
</style>
