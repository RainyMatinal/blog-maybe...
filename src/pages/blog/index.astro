---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PostList from '@/components/PostList.astro';
import { getPosts } from '@/lib/posts';

const lang = 'zh';
const posts = await getPosts(lang);
---

<BaseLayout lang={lang} title="博客" description="生活随笔、设计思考、旅行记录与产品评测。" switchTo="/en/blog">
  <section class="site-shell page-head">
    <p class="ui-font eyebrow">{posts.length} 篇文章</p>
    <h1 class="ui-font">博客</h1>
  </section>
  <section class="site-shell section-space">
    <PostList posts={posts} lang={lang} />
  </section>
</BaseLayout>

<style>
  .page-head {
    padding-top: 80px;
  }

  .eyebrow {
    margin: 0 0 8px;
    color: var(--color-muted);
    font-size: 13px;
  }

  h1 {
    margin: 0;
    font-size: 40px;
    font-weight: 500;
    line-height: 1.2;
    letter-spacing: 0;
  }

  @media (max-width: 640px) {
    h1 {
      font-size: 28px;
    }
  }
</style>
