---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PostList from '@/components/PostList.astro';
import { getPosts, type BlogPost } from '@/lib/posts';
import type { GetStaticPaths, Page } from 'astro';

export const getStaticPaths = (async ({ paginate }) => {
  const posts = await getPosts('en');
  return paginate(posts, { pageSize: 10 });
}) satisfies GetStaticPaths;

const page = Astro.props.page as Page<BlogPost>;
---

<BaseLayout lang="en" title={`Blog Page ${page.currentPage}`} description="Essays on life, design, travel, and thoughtful products." switchTo="/blog">
  <section class="site-shell page-head">
    <p class="ui-font eyebrow">{page.total} posts</p>
    <h1 class="ui-font">Blog</h1>
  </section>
  <section class="site-shell section-space">
    <PostList posts={page.data} lang="en" />
    <nav class="pager ui-font" aria-label="Pagination">
      {page.url.prev && <a href={page.url.prev}>Previous</a>}
      <span>{page.currentPage} / {page.lastPage}</span>
      {page.url.next && <a href={page.url.next}>Next</a>}
    </nav>
  </section>
</BaseLayout>

<style>
  .page-head {
    padding-top: 88px;
  }

  .eyebrow {
    width: fit-content;
    margin: 0 0 12px;
    padding: 2px 12px;
    border: 2px solid var(--color-border);
    border-radius: 18px 12px 20px 13px / 12px 18px 10px 16px;
    background: var(--color-accent-2);
    box-shadow: var(--shadow-doodle-small);
    color: #fffdf3;
    font-size: 18px;
    font-weight: 700;
    transform: rotate(-2deg);
  }

  h1 {
    margin: 0;
    font-family: 'Gaegu', 'DM Sans', sans-serif;
    font-size: 78px;
    font-weight: 700;
    letter-spacing: 0;
    text-shadow: 4px 4px 0 var(--color-surface-strong);
  }

  .pager {
    display: flex;
    justify-content: center;
    gap: 20px;
    margin-top: 40px;
    color: var(--color-text);
    font-size: 18px;
    font-weight: 700;
  }
</style>
