---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Cover from '@/components/Cover.astro';
import ReadingTime from '@/components/ReadingTime.astro';
import TOC from '@/components/TOC.astro';
import TagPill from '@/components/TagPill.astro';
import { formatDate, getPostSlug, getPosts, getTranslation, type BlogPost } from '@/lib/posts';
import { localizedPath } from '@/i18n/utils';

export async function getStaticPaths() {
  const posts = await getPosts('en');
  return posts.map((post) => ({
    params: { slug: getPostSlug(post) },
    props: { post }
  }));
}

const post = Astro.props.post as BlogPost;
const posts = await getPosts('en');
const index = posts.findIndex((entry) => entry.id === post.id);
const prevPost = posts[index + 1];
const nextPost = posts[index - 1];
const translation = await getTranslation(post, 'zh');
const { Content, headings } = await post.render();
const switchTo = translation ? localizedPath('zh', `/blog/${getPostSlug(translation)}`) : '/';
---

<BaseLayout lang="en" title={post.data.title} description={post.data.description} image={post.data.cover} switchTo={switchTo}>
  <article>
    <header class="reading-width post-head">
      <nav class="breadcrumb ui-font" aria-label="Breadcrumb">
        <a href="/en/">Home</a>
        <span>→</span>
        <a href="/en/blog">Blog</a>
        <span>→</span>
        <span>{post.data.title}</span>
      </nav>
      <h1 class="ui-font">{post.data.title}</h1>
      <div class="tag-row">
        {post.data.tags.map((tag) => <TagPill tag={tag} />)}
      </div>
      <div class="meta ui-font">
        <span>Published {formatDate(post.data.pubDate, 'en')}</span>
        <span>Read <ReadingTime text={post.body} lang="en" /></span>
        <a href={switchTo}>中文</a>
      </div>
    </header>

    {post.data.cover && (
      <div class="reading-width cover-wrap">
        <Cover src={post.data.cover} alt={post.data.title} eager />
      </div>
    )}

    <div class="article-grid">
      <div class="article-prose">
        <Content />
      </div>
      <TOC headings={headings} title="Contents" />
    </div>

    <footer class="reading-width post-footer">
      <div class="post-nav ui-font">
        <div>
          <span>Previous</span>
          {prevPost ? <a href={localizedPath('en', `/blog/${getPostSlug(prevPost)}`)}>{prevPost.data.title}</a> : <em>None</em>}
        </div>
        <div>
          <span>Next</span>
          {nextPost ? <a href={localizedPath('en', `/blog/${getPostSlug(nextPost)}`)}>{nextPost.data.title}</a> : <em>None</em>}
        </div>
      </div>
      <div class="tag-cloud">
        {post.data.tags.map((tag) => <TagPill tag={tag} />)}
      </div>
    </footer>
  </article>
</BaseLayout>

<style>
  .post-head {
    padding-top: 72px;
  }

  .breadcrumb,
  .meta {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    color: var(--color-muted);
    font-size: 12px;
    line-height: 1.5;
  }

  h1 {
    display: -webkit-box;
    overflow: hidden;
    margin: 24px 0 18px;
    font-size: 40px;
    font-weight: 500;
    line-height: 1.2;
    letter-spacing: 0;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 3;
  }

  .tag-row,
  .tag-cloud {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .meta {
    margin-top: 16px;
  }

  .meta a {
    color: var(--color-accent);
  }

  .cover-wrap {
    margin-top: 40px;
  }

  .article-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: 48px;
    margin-top: 56px;
  }

  .post-footer {
    margin-top: 72px;
    padding-top: 32px;
    border-top: 1px solid var(--color-border);
  }

  .post-nav {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 24px;
    margin-bottom: 28px;
    font-size: 14px;
    line-height: 1.6;
  }

  .post-nav div {
    display: grid;
    gap: 6px;
  }

  .post-nav span,
  .post-nav em {
    color: var(--color-muted);
    font-style: normal;
  }

  @media (min-width: 1280px) {
    .article-grid {
      grid-template-columns: 1fr 220px;
      width: min(100% - 32px, 1180px);
      margin-inline: auto;
    }

    .article-prose {
      margin-left: auto;
      margin-right: 68px;
    }
  }

  @media (max-width: 640px) {
    h1 {
      font-size: 28px;
    }

    .post-nav {
      grid-template-columns: 1fr;
    }
  }
</style>
