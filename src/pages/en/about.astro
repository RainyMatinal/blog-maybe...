---
import { getEntry } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '@/layouts/BaseLayout.astro';

const lang = 'en';
const about = await getEntry('about', 'en');
if (!about) throw new Error('Missing en about content');
const { Content } = await about.render();
---

<BaseLayout lang={lang} title={about.data.title} description={about.data.description} switchTo="/about">
  <section class="site-shell about-hero">
    <Image src="/images/profile.svg" alt="Author portrait: an abstract side profile on a warm paper background" width={360} height={360} loading="eager" />
    <div>
      <p class="ui-font eyebrow">Creator / Visual Notes</p>
      <h1 class="ui-font">Hello, I am Lin.</h1>
      <p>I like living at a slower rhythm and looking at design with a clearer eye.</p>
    </div>
  </section>

  <section class="article-prose about-content">
    <Content />
  </section>

  <section class="reading-width socials ui-font" aria-label="Social links">
    <a href="https://instagram.com">Instagram</a>
    <a href="https://twitter.com">Twitter-X</a>
    <a href="https://github.com">GitHub</a>
    <a href="mailto:hello@example.com">Email</a>
    <a href="/en/rss.xml">RSS</a>
  </section>
</BaseLayout>

<style>
  .about-hero {
    display: grid;
    grid-template-columns: 260px minmax(0, 1fr);
    gap: 64px;
    align-items: center;
    padding-top: 88px;
  }

  img {
    width: 100%;
    aspect-ratio: 1;
    object-fit: cover;
    border: var(--border-doodle);
    border-radius: 45% 55% 48% 52% / 50% 44% 56% 50%;
    background: var(--color-surface-strong);
    box-shadow: var(--shadow-doodle);
    transform: rotate(-3deg);
  }

  .eyebrow {
    width: fit-content;
    margin: 0 0 14px;
    padding: 2px 12px;
    border: 2px solid var(--color-border);
    border-radius: 18px 12px 20px 13px / 12px 18px 10px 16px;
    background: var(--color-accent-2);
    box-shadow: var(--shadow-doodle-small);
    color: #fffdf3;
    font-size: 18px;
    font-weight: 700;
    transform: rotate(2deg);
  }

  h1 {
    margin: 0 0 18px;
    font-family: 'Gaegu', 'DM Sans', sans-serif;
    font-size: 66px;
    font-weight: 700;
    line-height: 1.05;
    letter-spacing: 0;
    text-shadow: 4px 4px 0 var(--color-surface-strong);
  }

  .about-hero p:last-child {
    width: fit-content;
    padding: 8px 14px;
    border: var(--border-doodle);
    border-radius: 24px 14px 28px 16px / 15px 26px 14px 22px;
    background: var(--color-surface);
    box-shadow: var(--shadow-doodle-small);
    margin: 0;
    color: var(--color-text);
    font-weight: 700;
    transform: rotate(-1deg);
  }

  .about-content {
    margin-top: 80px;
  }

  .socials {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    margin-top: 56px;
    font-size: 18px;
    font-weight: 700;
  }

  .socials a {
    padding: 2px 10px;
    border: 2px solid var(--color-border);
    border-radius: 18px 12px 20px 13px / 12px 18px 10px 16px;
    background: var(--color-surface);
    box-shadow: 3px 3px 0 var(--color-shadow);
    color: var(--color-text);
  }

  .socials a:hover {
    background: var(--color-accent);
    box-shadow: 1px 1px 0 var(--color-shadow);
    color: #fffdf3;
    transform: translate(2px, 2px) rotate(-2deg);
  }

  @media (max-width: 720px) {
    .about-hero {
      grid-template-columns: 1fr;
      gap: 32px;
    }

    .about-hero img {
      max-width: 260px;
    }

    h1 {
      font-size: 46px;
    }
  }
</style>
