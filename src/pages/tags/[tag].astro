---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import PostCard from "../../components/blog/PostCard.astro";

export async function getStaticPaths() {
  const tagSlug = (tag: string) =>
    encodeURIComponent(tag.trim().toLowerCase().replace(/\s+/g, "-"));

  const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
  );

  const tags = new Map<string, string>();
  for (const post of posts) {
    for (const tag of post.data.tags) {
      tags.set(tagSlug(tag), tag);
    }
  }

  return Array.from(tags.entries()).map(([slug, tag]) => ({
    params: { tag: slug },
    props: {
      tag,
      posts: posts.filter((post) => post.data.tags.includes(tag)),
    },
  }));
}

const { tag, posts } = Astro.props;
const postHref = (id: string) => `/blog/${id.replace(/\.mdx?$/, "")}`;
const categories = [...new Set(posts.map((post) => post.data.category))];
---

<BaseLayout
  title={`Tag: ${tag}`}
  description={`RainyMatinal Network Archive 中带有 ${tag} 标签的文章。`}
>
  <section class="tag-page" aria-labelledby="tag-title">
    <header class="tag-hero window-card">
      <div class="window-titlebar">
        <span class="window-dot dot-red" aria-hidden="true"></span>
        <span class="window-dot dot-yellow" aria-hidden="true"></span>
        <span class="window-dot dot-green" aria-hidden="true"></span>
        <span>finder.exe - tag://{tag}</span>
      </div>

      <div class="tag-hero__body">
        <div>
          <p class="section-kicker">Subject Folder</p>
          <h1 id="tag-title">#{tag}</h1>
          <p>这个资料夹收纳了所有带有该主题词的公开记录。</p>
        </div>

        <dl class="tag-stats" aria-label="标签统计">
          <div>
            <dt>Records</dt>
            <dd>{posts.length}</dd>
          </div>
          <div>
            <dt>Categories</dt>
            <dd>{categories.length}</dd>
          </div>
        </dl>
      </div>
    </header>

    <div class="tag-layout">
      <aside class="tag-side window-card" aria-label="标签资料夹信息">
        <div class="window-titlebar">
          <span class="window-dot dot-green" aria-hidden="true"></span>
          <span>tag-folder.ini</span>
        </div>
        <div class="tag-side__body">
          <p class="side-label">Tag</p>
          <strong>#{tag}</strong>
          <p class="side-label">Categories</p>
          <ul>
            {categories.map((category) => (
              <li>
                <span class="status-light active" aria-hidden="true"></span>
                {category}
              </li>
            ))}
          </ul>
          <a class="old-button" href="/tags/">返回标签索引</a>
        </div>
      </aside>

      <div class="tag-post-list" aria-label={`${tag} 标签文章列表`}>
        {posts.map((post, index) => (
          <PostCard
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            category={post.data.category}
            tags={post.data.tags}
            href={postHref(post.id)}
            index={index}
          />
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .tag-page {
    display: grid;
    gap: var(--space-7);
  }

  .tag-hero,
  .tag-side {
    overflow: hidden;
  }

  .tag-hero__body {
    align-items: end;
    background:
      radial-gradient(circle at 82% 22%, rgba(111, 255, 233, 0.28), transparent 14rem),
      linear-gradient(180deg, rgba(255, 255, 255, 0.74), rgba(232, 247, 255, 0.54));
    display: grid;
    gap: var(--space-5);
    grid-template-columns: minmax(0, 1fr) auto;
    padding: clamp(1.5rem, 4vw, 3rem);
  }

  .tag-hero h1 {
    font-size: clamp(2.2rem, 6vw, 4rem);
    margin-bottom: var(--space-3);
    overflow-wrap: anywhere;
  }

  .tag-hero p {
    color: var(--text-muted);
    font-size: 1.08rem;
    line-height: 1.9;
    margin: 0;
  }

  .tag-stats {
    display: grid;
    gap: var(--space-3);
    grid-template-columns: repeat(2, minmax(6rem, 1fr));
    margin: 0;
  }

  .tag-stats div {
    background: var(--bg-panel-soft);
    border: 1px solid rgba(94, 200, 255, 0.34);
    border-radius: 8px;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.82);
    padding: var(--space-3);
  }

  .tag-stats dt,
  .side-label {
    color: var(--text-soft);
    font-family: Tahoma, var(--font-mono);
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
  }

  .tag-stats dd {
    color: var(--color-system-blue);
    font-family: var(--font-mono);
    font-size: 1.35rem;
    font-weight: 800;
    margin: 0;
  }

  .tag-layout {
    align-items: start;
    display: grid;
    gap: var(--space-5);
    grid-template-columns: minmax(13rem, 0.28fr) minmax(0, 1fr);
  }

  .tag-side {
    position: sticky;
    top: var(--space-5);
  }

  .tag-side__body {
    display: grid;
    gap: var(--space-3);
    padding: var(--space-4);
  }

  .tag-side strong,
  .tag-side li {
    font-family: var(--font-mono);
    font-size: 0.86rem;
    overflow-wrap: anywhere;
  }

  .tag-side ul {
    display: grid;
    gap: var(--space-2);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .tag-side li {
    align-items: center;
    display: flex;
    gap: var(--space-2);
  }

  .tag-post-list {
    display: grid;
    gap: var(--space-5);
  }

  @media (max-width: 860px) {
    .tag-hero__body,
    .tag-layout {
      grid-template-columns: 1fr;
    }

    .tag-side {
      position: static;
    }
  }

  @media (max-width: 560px) {
    .tag-stats {
      grid-template-columns: 1fr;
    }
  }
</style>
