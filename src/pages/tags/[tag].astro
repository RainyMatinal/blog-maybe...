---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import PostCard from "../../components/blog/PostCard.astro";

const postHref = (id: string) => `/blog/${id.replace(/\.mdx?$/, "")}/`;

export async function getStaticPaths() {
  const tagSlug = (tag: string) => encodeURIComponent(tag.trim().toLowerCase().replace(/\s+/g, "-"));
  const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
  );

  const tags = new Map<string, string>();
  for (const post of posts) {
    for (const tag of post.data.tags) tags.set(tagSlug(tag), tag);
  }

  return Array.from(tags.entries()).map(([slug, tag]) => ({
    params: { tag: slug },
    props: {
      tag,
      posts: posts.filter((post) => post.data.tags.includes(tag)),
    },
  }));
}

const { tag, posts } = Astro.props;
const categories = [...new Set(posts.map((post) => post.data.category))];
---

<BaseLayout title={`#${tag}`} description={`RainyMatinal 苦难摇篮中带有 #${tag} 标签的文章。`}>
  <section class="page-title-section tag-title-section">
    <div class="title-overlap-wrapper">
      <span class="huge-bg-en">FOLDER</span>
      <h1 class="solid-fg-cn">#{tag}</h1>
    </div>
    <div class="title-divider"></div>
  </section>

  <main class="tag-folder-page">
    <aside class="tag-side-window" aria-label="标签资料夹信息">
      <div class="window-titlebar">
        <span class="window-dot dot-green" aria-hidden="true"></span>
        <span>tag-folder.ini</span>
      </div>
      <div class="tag-side-body">
        <p class="side-label">Tag</p>
        <strong>#{tag}</strong>
        <div class="tag-stats">
          <div><span>Records</span><b>{posts.length}</b></div>
          <div><span>Categories</span><b>{categories.length}</b></div>
        </div>
        <p class="side-label">Categories</p>
        <ul>
          {categories.map((category) => (
            <li><span class="status-light active" aria-hidden="true"></span>{category}</li>
          ))}
        </ul>
        <a class="folder-back-link" href="/tags/" data-search-title="标签索引" data-search-desc="返回所有标签">返回标签索引</a>
      </div>
    </aside>

    <section class="tag-post-area" aria-label={`${tag} 标签文章列表`}>
      <div class="tag-folder-intro">
        <p>这个资料夹收纳了所有带有该主题词的公开来信。内容顺序按投递日期从新到旧排列。</p>
      </div>
      <div class="ticket-grid">
        {posts.map((post, index) => (
          <PostCard
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            category={post.data.category}
            tags={post.data.tags}
            href={postHref(post.id)}
            heroImage={post.data.heroImage}
            index={index}
          />
        ))}
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .tag-title-section {
    padding-bottom: 2rem;
  }

  .tag-folder-page {
    display: grid;
    grid-template-columns: minmax(14rem, 250px) minmax(0, 1fr);
    gap: 2rem;
    width: min(1320px, calc(100% - 8vw));
    margin: 0 auto 6rem;
  }

  .tag-side-window,
  .tag-folder-intro {
    background: rgba(250, 250, 250, 0.84);
    border: 1px solid var(--theme-line);
    box-shadow: 0 18px 42px rgba(20, 43, 66, 0.1);
  }

  .tag-side-window {
    overflow: hidden;
    align-self: start;
    position: sticky;
    top: 7rem;
  }

  .tag-side-body {
    display: grid;
    gap: 1rem;
    padding: 1rem;
  }

  .side-label,
  .tag-stats span {
    color: #999;
    font-family: var(--font-mono);
    font-size: 0.68rem;
    font-weight: 900;
    letter-spacing: 0.12em;
    margin: 0;
    text-transform: uppercase;
  }

  .tag-side-body > strong {
    color: var(--theme-stamp-red);
    font-family: var(--font-serif);
    font-size: 1.7rem;
    overflow-wrap: anywhere;
  }

  .tag-stats {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.6rem;
  }

  .tag-stats div {
    border: 1px dashed rgba(20, 43, 66, 0.18);
    background: #fff;
    padding: 0.7rem;
  }

  .tag-stats b {
    display: block;
    color: var(--theme-blue);
    font-family: var(--font-mono);
    font-size: 1.25rem;
    margin-top: 0.25rem;
  }

  .tag-side-body ul {
    display: grid;
    gap: 0.55rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .tag-side-body li {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    color: #555;
    font-size: 0.9rem;
    line-height: 1.5;
  }

  .folder-back-link {
    display: inline-flex;
    justify-content: center;
    border: 1px dashed #c9c5bb;
    color: #666;
    font-weight: 800;
    padding: 0.55rem 0.8rem;
    text-decoration: none;
    transition: border-color 0.25s ease, color 0.25s ease, transform 0.25s ease;
  }

  .folder-back-link:hover {
    border-color: var(--theme-blue);
    color: var(--theme-blue);
    transform: translateY(-2px);
  }

  .tag-post-area {
    min-width: 0;
  }

  .tag-folder-intro {
    margin-bottom: 2rem;
    padding: 1rem 1.25rem;
  }

  .tag-folder-intro p {
    color: #666;
    line-height: 1.8;
    margin: 0;
  }

  .ticket-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(330px, 1fr));
    gap: 3rem;
  }

  @media (max-width: 920px) {
    .tag-folder-page {
      grid-template-columns: 1fr;
    }

    .tag-side-window {
      position: static;
    }
  }

  @media (max-width: 560px) {
    .tag-folder-page {
      width: min(100% - 2rem, 1320px);
    }

    .ticket-grid,
    .tag-stats {
      grid-template-columns: 1fr;
    }
  }
</style>