---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const tagSlug = (tag: string) => encodeURIComponent(tag.trim().toLowerCase().replace(/\s+/g, "-"));

const tagMap = new Map<string, { tag: string; count: number; categories: Set<string>; latest: (typeof posts)[number] }>();
for (const post of posts) {
  for (const tag of post.data.tags) {
    const current = tagMap.get(tag) ?? {
      tag,
      count: 0,
      categories: new Set<string>(),
      latest: post,
    };
    current.count += 1;
    current.categories.add(post.data.category);
    if (post.data.pubDate > current.latest.data.pubDate) current.latest = post;
    tagMap.set(tag, current);
  }
}

const tags = Array.from(tagMap.values()).sort((a, b) => b.count - a.count || a.tag.localeCompare(b.tag));
---

<BaseLayout title="标签索引" description="以旧互联网索引页的方式浏览 RainyMatinal 苦难摇篮的主题标签。">
  <section class="page-title-section tags-title-section">
    <div class="title-overlap-wrapper">
      <span class="huge-bg-en">FREQ</span>
      <h1 class="solid-fg-cn">标签</h1>
    </div>
    <div class="title-divider"></div>
  </section>

  <main class="tag-index-page" aria-labelledby="tag-index-title">
    <section class="tag-ledger-window">
      <div class="window-titlebar">
        <span class="window-dot dot-green" aria-hidden="true"></span>
        <span>subject-index.dat / {tags.length} tags</span>
      </div>

      <div class="tag-ledger-intro">
        <h2 id="tag-index-title">主题频段目录</h2>
        <p>每个标签都是一段频率：Linux、Git、网络工程、前端和长期学习路线，会在这里交叉成一张可回溯的主题地图。</p>
      </div>

      <div class="tag-grid">
        {tags.map(({ tag, count, categories, latest }, index) => (
          <a
            class="tag-card"
            href={`/tags/${tagSlug(tag)}/`}
            style={`--tag-rotate: ${index % 2 === 0 ? "-0.4deg" : "0.4deg"}`}
            data-search-title={`#${tag}`}
            data-search-desc={latest.data.title}
          >
            <span class="tag-card__serial">FREQ-{String(index + 1).padStart(2, "0")}</span>
            <span class="tag-card__name">#{tag}</span>
            <span class="tag-card__count">{count} records</span>
            <span class="tag-card__meta">{Array.from(categories).join(" / ")}</span>
            <span class="tag-card__latest">latest: {latest.data.title}</span>
          </a>
        ))}
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .tags-title-section {
    padding-bottom: 2rem;
  }

  .tag-index-page {
    width: min(1180px, calc(100% - 8vw));
    margin: 0 auto 6rem;
  }

  .tag-ledger-window {
    overflow: hidden;
    background: rgba(250, 250, 250, 0.84);
    border: 1px solid var(--theme-line);
    box-shadow: 0 20px 50px rgba(20, 43, 66, 0.12);
  }

  .tag-ledger-intro {
    padding: clamp(1.25rem, 3vw, 2rem) clamp(1.25rem, 4vw, 3rem);
    border-bottom: 1px dashed var(--theme-line);
  }

  .tag-ledger-intro h2 {
    color: #111;
    font-family: var(--font-serif);
    font-size: clamp(1.7rem, 4vw, 3rem);
    margin: 0 0 0.8rem;
  }

  .tag-ledger-intro p {
    max-width: 760px;
    color: #666;
    line-height: 1.9;
    margin: 0;
  }

  .tag-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(15rem, 1fr));
    gap: 1rem;
    padding: clamp(1rem, 3vw, 2rem);
  }

  .tag-card {
    position: relative;
    display: grid;
    gap: 0.55rem;
    min-height: 12rem;
    padding: 1rem;
    background:
      linear-gradient(135deg, rgba(178, 58, 58, 0.07), transparent 38%),
      #fff;
    border: 1px solid #e5e1d8;
    color: #111;
    text-decoration: none;
    transform: rotate(var(--tag-rotate));
    transition: transform 0.25s ease, border-color 0.25s ease, box-shadow 0.25s ease;
  }

  .tag-card::before,
  .tag-card::after {
    content: "";
    position: absolute;
    top: 50%;
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: var(--bg-color);
    transform: translateY(-50%);
  }

  .tag-card::before { left: -7px; }
  .tag-card::after { right: -7px; }

  .tag-card:hover {
    border-color: var(--theme-blue);
    box-shadow: 0 18px 38px rgba(20, 43, 66, 0.14);
    transform: translateY(-4px) rotate(0deg);
  }

  .tag-card__serial,
  .tag-card__count,
  .tag-card__latest {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 900;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .tag-card__serial {
    color: #999;
  }

  .tag-card__name {
    color: var(--theme-stamp-red);
    font-family: var(--font-serif);
    font-size: 1.55rem;
    font-weight: 900;
    line-height: 1.2;
    overflow-wrap: anywhere;
  }

  .tag-card__count {
    color: var(--theme-blue);
  }

  .tag-card__meta {
    color: #666;
    line-height: 1.65;
    overflow-wrap: anywhere;
  }

  .tag-card__latest {
    align-self: end;
    color: #999;
    overflow-wrap: anywhere;
  }

  @media (max-width: 560px) {
    .tag-index-page {
      width: min(100% - 2rem, 1180px);
    }
  }
</style>