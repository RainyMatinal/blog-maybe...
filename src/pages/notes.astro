---
import BaseLayout from '@/layouts/BaseLayout.astro';
import LedgerRows from '@/components/LedgerRows.astro';
import NotesBoard from '@/components/NotesBoard.astro';

const lang = 'zh';
---

<BaseLayout lang={lang} title="笔记" description="随手写下的小块笔记与源文件维护的手账。">
  <section class="site-shell notes-page-intro">
    <p class="intro-kicker">Rainy Notes</p>
    <h1>笔记</h1>
    <p>
      上方保留即时便签板；下方是只从源文件生成的手账列表。页面不承担编辑功能，内容以发布时间进入归档。
    </p>
  </section>

  <NotesBoard lang={lang} title="笔记" subtitle="手绘笔记" />
  <LedgerRows />
</BaseLayout>

<style>
  .notes-page-intro {
    display: grid;
    gap: 10px;
    max-width: 820px;
    padding-top: 76px;
    padding-bottom: 10px;
    text-align: center;
  }

  .intro-kicker {
    margin: 0;
    color: var(--color-accent);
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .notes-page-intro h1 {
    margin: 0;
    color: var(--color-text);
    font-family: 'Noto Serif SC', serif;
    font-size: clamp(42px, 9vw, 84px);
    line-height: 1.12;
  }

  .notes-page-intro p:last-child {
    margin: 0;
    color: var(--color-muted);
    font-size: clamp(16px, 2.5vw, 19px);
    line-height: 1.9;
  }
</style>
