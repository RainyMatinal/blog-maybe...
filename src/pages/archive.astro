---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";

const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const postHref = (id: string) => `/blog/${id.replace(/\.mdx?$/, "")}`;
const formatMonthDay = (date: Date) => new Intl.DateTimeFormat("en-US", { month: "short", day: "2-digit" }).format(date).toUpperCase();
const groups = Array.from(posts.reduce((map, post) => {
  const year = post.data.pubDate.getFullYear();
  const list = map.get(year) ?? [];
  list.push(post);
  map.set(year, list);
  return map;
}, new Map<number, typeof posts>())).sort(([a], [b]) => b - a);
---

<BaseLayout title="往期" description="RainyMatinal 苦难摇篮的年份归档。">
  <section class="page-title-section">
    <div class="title-overlap-wrapper">
      <span class="huge-bg-en">ARCHIVE</span>
      <h1 class="solid-fg-cn">往期</h1>
    </div>
    <div class="title-divider"></div>
  </section>

  <main class="page-container">
    <div class="content-wrapper">
      <div class="archive-timeline">
        <div class="telegraph-line" aria-hidden="true"></div>
        <div class="signal-start">
          <span class="signal-dot" aria-hidden="true"></span>
          <p class="signal-text">SIGNAL LOCKED // <span>{posts.length}</span> DISPATCHES FOUND</p>
        </div>

        {groups.map(([year, group]) => (
          <section class="year-group" aria-labelledby={`year-${year}`}>
            <div class="year-header">
              <h2 class="year-stamp" id={`year-${year}`}>{year}</h2>
            </div>
            {group.map((post) => (
              <article class="timeline-item">
                <span class="signal-node" aria-hidden="true"></span>
                <div class="archive-postmark" aria-hidden="true">
                  <div class="postmark-circle">
                    <div class="postmark-inner">
                      <span class="postmark-date">{formatMonthDay(post.data.pubDate)}</span>
                      <span class="postmark-location">RM</span>
                    </div>
                  </div>
                </div>
                <a class="post-content-link" href={postHref(post.id)} data-search-title={post.data.title} data-search-desc={post.data.description}>
                  <h3 class="post-title">{post.data.title}</h3>
                  <p class="post-excerpt">{post.data.description}</p>
                  <div class="post-tags">
                    {post.data.tags.map((tag) => <span class="tag-item">#{tag}</span>)}
                  </div>
                </a>
              </article>
            ))}
          </section>
        ))}
      </div>
    </div>
  </main>
</BaseLayout>

<style>
  .page-container {
    width: 100%;
    min-height: calc(100vh - 80px);
    overflow-x: hidden;
    background-color: var(--bg-color);
    padding-top: 80px;
    padding-bottom: 8rem;
  }

  .content-wrapper {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 6vw;
  }

  .archive-timeline {
    position: relative;
    margin-top: 4rem;
    padding-bottom: 4rem;
  }

  .telegraph-line {
    position: absolute;
    top: 30px;
    bottom: 0;
    left: 200px;
    z-index: 1;
    width: 2px;
    margin-left: -1px;
    background-image: linear-gradient(to bottom, var(--theme-line) 50%, transparent 50%);
    background-size: 2px 12px;
  }

  .signal-start {
    position: relative;
    display: flex;
    align-items: center;
    min-height: 24px;
    margin-bottom: 6rem;
    padding-left: 250px;
  }

  .signal-dot {
    position: absolute;
    left: 200px;
    top: 6px;
    z-index: 2;
    width: 10px;
    height: 10px;
    margin-left: -5px;
    border-radius: 50%;
    background-color: var(--theme-mintcyan);
    box-shadow: 0 0 10px var(--theme-mintcyan);
    animation: pulse-cyan 2.5s infinite cubic-bezier(0.4, 0, 0.6, 1);
  }

  @keyframes pulse-cyan {
    0%, 100% { opacity: 0.8; transform: scale(1); box-shadow: 0 0 8px var(--theme-mintcyan); }
    50% { opacity: 0.3; transform: scale(0.85); box-shadow: 0 0 2px var(--theme-mintcyan); }
  }

  .signal-text {
    color: #666;
    font-size: clamp(0.85rem, 4vw, 0.95rem);
    font-weight: 600;
    letter-spacing: 0.05em;
    line-height: 1.6;
    margin: 0;
    white-space: nowrap;
  }

  .signal-text span {
    color: var(--theme-blue);
    font-variant-numeric: tabular-nums;
    font-weight: 900;
  }

  .year-group {
    position: relative;
    margin-bottom: 4rem;
  }

  .year-header {
    position: relative;
    height: 80px;
    margin-bottom: 3rem;
  }

  .year-stamp {
    position: absolute;
    left: -50px;
    top: 0;
    z-index: 10;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 6px solid var(--theme-stamp-red);
    border-radius: 6px;
    background: transparent;
    color: var(--theme-stamp-red);
    font-size: 3.5rem;
    font-variant-numeric: tabular-nums;
    font-weight: 900;
    letter-spacing: 0.05em;
    line-height: 1;
    mix-blend-mode: multiply;
    padding: 16px 36px;
  }

  .timeline-item {
    position: relative;
    display: block;
    margin-bottom: 4rem;
    padding-left: 250px;
  }

  .signal-node {
    position: absolute;
    left: 200px;
    top: 14px;
    z-index: 5;
    width: 12px;
    height: 12px;
    margin-left: -6px;
    border: 2px solid #b0aba1;
    border-radius: 50%;
    background-color: var(--bg-color);
    transition: all 0.3s cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  .archive-postmark {
    --stamp-ink: var(--theme-blue);
    position: absolute;
    right: -60px;
    top: 0;
    z-index: 1;
    display: flex;
    align-items: center;
    opacity: 0.45;
    mix-blend-mode: multiply;
    pointer-events: none;
    transform: scale(1.3) rotate(-10deg);
    transform-origin: center;
    transition: opacity 0.4s ease;
  }

  .postmark-circle {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 76px;
    height: 76px;
    border: 2px solid var(--stamp-ink);
    border-radius: 50%;
    padding: 4px;
  }

  .postmark-inner {
    display: flex;
    flex: 1;
    width: 100%;
    height: 100%;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    border: 1px dashed var(--stamp-ink);
    border-radius: 50%;
    color: var(--stamp-ink);
  }

  .postmark-date {
    font-size: 0.85rem;
    font-weight: 900;
    letter-spacing: 0.05em;
    line-height: 1;
    margin-bottom: 2px;
  }

  .postmark-location {
    border-top: 1px solid var(--stamp-ink);
    font-size: 0.5rem;
    letter-spacing: 2px;
    padding-top: 2px;
  }

  .post-content-link {
    position: relative;
    z-index: 2;
    display: block;
    padding-right: 150px;
    text-decoration: none;
  }

  .post-title {
    color: #111;
    font-family: "Noto Serif SC", var(--font-serif);
    font-size: 2.1rem;
    font-weight: 900;
    line-height: 1.3;
    margin: 0 0 0.8rem;
    transition: color 0.3s ease;
  }

  .post-excerpt {
    display: -webkit-box;
    overflow: hidden;
    color: #666;
    font-size: 1rem;
    line-height: 1.7;
    margin: 0 0 1.2rem;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .tag-item {
    color: #999;
    font-size: 0.95rem;
    font-weight: 600;
    transition: color 0.3s ease;
  }

  .timeline-item:hover .post-title,
  .timeline-item:hover .tag-item {
    color: var(--theme-blue);
  }

  .timeline-item:hover .archive-postmark {
    opacity: 1;
  }

  @keyframes pulse-orange {
    0%, 100% { transform: scale(1.4); box-shadow: 0 0 12px var(--theme-persimmonorange); }
    50% { transform: scale(1); box-shadow: 0 0 4px var(--theme-persimmonorange); }
  }

  .timeline-item:hover .signal-node {
    border-color: var(--theme-persimmonorange);
    background-color: var(--theme-persimmonorange);
    animation: pulse-orange 2s infinite cubic-bezier(0.4, 0, 0.6, 1);
  }

  @media (max-width: 900px) {
    .content-wrapper { padding: 0 4vw; }
    .telegraph-line { left: 30px; }
    .signal-start { padding-left: 60px; }
    .signal-dot { left: 30px; }
    .year-header { height: 50px; }
    .year-stamp {
      left: 0;
      display: inline-block;
      width: auto;
      border-width: 4px;
      font-size: 2.5rem;
      padding: 4px 12px;
    }
    .timeline-item { padding-left: 60px; }
    .signal-node { left: 30px; top: 16px; }
    .post-content-link { padding-right: 0; }
    .archive-postmark { right: -10px; top: -10px; opacity: 0.12; transform: scale(1.4) rotate(-15deg); }
    .timeline-item:hover .archive-postmark { opacity: 0.25; transform: scale(1.4) rotate(-15deg); }
    .post-title { font-size: 1.6rem; }
  }
</style>