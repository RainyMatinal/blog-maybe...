---
import { getEntry } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '@/layouts/BaseLayout.astro';

const lang = 'zh';
const about = await getEntry('about', 'zh');
if (!about) throw new Error('Missing zh about content');
const { Content } = await about.render();
---

<BaseLayout lang={lang} title={about.data.title} description={about.data.description} switchTo="/en/about">
  <section class="site-shell about-hero">
    <Image src="/images/profile.svg" alt="博主头像：柔和纸色背景上的抽象侧影" width={360} height={360} loading="eager" />
    <div>
      <p class="ui-font eyebrow">Creator / Visual Notes</p>
      <h1 class="ui-font">你好，我是 Lin。</h1>
      <p>喜欢把生活过得慢一点，也喜欢把设计看得清一点。</p>
    </div>
  </section>

  <section class="article-prose about-content">
    <Content />
  </section>

  <section class="reading-width socials ui-font" aria-label="社交链接">
    <a href="https://instagram.com">Instagram</a>
    <a href="https://twitter.com">Twitter-X</a>
    <a href="https://github.com">GitHub</a>
    <a href="mailto:hello@example.com">Email</a>
    <a href="/rss.xml">RSS</a>
  </section>
</BaseLayout>

<style>
  .about-hero {
    display: grid;
    grid-template-columns: 260px minmax(0, 1fr);
    gap: 64px;
    align-items: center;
    padding-top: 88px;
  }

  img {
    width: 100%;
    aspect-ratio: 1;
    object-fit: cover;
    border: 1px solid var(--color-border);
  }

  .eyebrow {
    margin: 0 0 12px;
    color: var(--color-muted);
    font-size: 12px;
  }

  h1 {
    margin: 0 0 18px;
    font-size: 40px;
    font-weight: 500;
    line-height: 1.2;
    letter-spacing: 0;
  }

  .about-hero p:last-child {
    margin: 0;
    color: var(--color-muted);
  }

  .about-content {
    margin-top: 80px;
  }

  .socials {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    margin-top: 56px;
    font-size: 14px;
  }

  .socials a {
    border-bottom: 1px solid var(--color-border);
    color: var(--color-muted);
  }

  @media (max-width: 720px) {
    .about-hero {
      grid-template-columns: 1fr;
      gap: 32px;
    }

    .about-hero img {
      max-width: 260px;
    }

    h1 {
      font-size: 28px;
    }
  }
</style>
