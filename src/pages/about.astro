---
import BaseLayout from "../layouts/BaseLayout.astro";

const learningItems = [
  ["Linux", "daily system", "把 Arch Linux 当作长期工作台，记录安装、桌面环境、输入法、包管理和日常排错。"],
  ["Git / GitHub", "version habit", "练习 SSH、remote、分支、提交和同步，把每一次报错都变成以后能查到的笔记。"],
  ["C 语言", "foundation", "回到计算机基础，把语法、编译、指针和调试一点点啃下来。"],
  ["Frontend", "site craft", "用 Astro、HTML 和 CSS 搭建自己的网络空间，同时整理内容结构。"],
  ["Network", "field notes", "记录 VLAN、STP、DHCP、H3C 配置和现场排障思路。"],
  ["考研路线", "long run", "把长期学习拆成阶段计划、复盘和资料索引，让目标不只停留在口头上。"],
];

const routeSteps = [
  ["01", "系统工作台", "Linux 安装、软件源、输入法、开发环境、终端习惯。"],
  ["02", "版本控制", "Git 基础、GitHub SSH、仓库同步、提交记录。"],
  ["03", "编程基础", "C 语言、编译工具链、调试和计算机基础知识。"],
  ["04", "前端与博客", "Astro、组件、CSS tokens、静态构建和内容集合。"],
  ["05", "网络工程", "VLAN、Access / Trunk、DHCP、H3C CLI 和拓扑排障。"],
  ["06", "长期考试路线", "考研信息、阶段目标、复盘和可持续学习节奏。"],
];

const categoryNotes = [
  ["LINUX", "系统安装、桌面环境、输入法、包管理和排错记录。"],
  ["GIT", "GitHub SSH、remote、提交习惯和仓库同步问题。"],
  ["C / FRONTEND", "C 语言基础、Astro、HTML、CSS 和组件实验。"],
  ["NETWORK", "VLAN、STP、DHCP、H3C 配置和现场问题复盘。"],
  ["EXAM", "考研路线、阶段计划、学习复盘和资料整理。"],
  ["PERSONAL", "旧互联网审美、个人观察和技术之外的随笔。"],
];

const futurePlans = [
  "继续补齐 Linux、Git、C、前端和网络工程的基础笔记。",
  "把真实排障过程整理成可复查的档案，而不是散落在聊天记录里。",
  "完善 archive、tags、about 和未来的 lab 入口。",
  "给考研路线建立长期复盘节奏，记录每个阶段的目标和偏差。",
  "保留一点旧互联网的清澈感，让这个站点像一间长期在线的技术房间。",
];
---

<BaseLayout title="关于" description="关于 RainyMatinal 苦难摇篮，一个记录技术学习路线的个人网络空间。" bodyClass="about-starry-body">
  <section class="star-page" aria-labelledby="about-title">
    <div class="star-bg-layer" aria-hidden="true">
      <span class="planet planet-red"></span>
      <span class="planet planet-blue"></span>
      <span class="orbit-line orbit-one"></span>
      <span class="orbit-line orbit-two"></span>
    </div>

    <header class="page-title-section about-title-section">
      <div class="title-overlap-wrapper">
        <span class="huge-bg-en">ABOUT</span>
        <h1 class="solid-fg-cn" id="about-title">孤星</h1>
      </div>
      <div class="title-divider"></div>
    </header>

    <main class="about-bento">
      <section class="bento-card intro-card">
        <p class="card-kicker">PERSONAL NETWORK ROOM</p>
        <h2>这不是简历，是一间正在搭建的技术房间。</h2>
        <p>
          我正在学习 Linux、Git、C 语言、前端、网络工程和考研路线。这个博客是我的个人技术档案馆，记录配置、报错、命令、复盘和那些暂时还不熟练但值得认真保存的过程。
        </p>
      </section>

      <section class="bento-card status-card">
        <p class="card-kicker">CURRENT SIGNALS</p>
        <div class="signal-lines">
          {learningItems.map(([name, status, text]) => (
            <article>
              <span>{status}</span>
              <h3>{name}</h3>
              <p>{text}</p>
            </article>
          ))}
        </div>
      </section>

      <section class="bento-card why-card">
        <p class="card-kicker">WHY BLOG</p>
        <h2>把学习过程变成未来能搜索到的记忆。</h2>
        <p>
          学习里有很多瞬间很容易消失：一次配置成功、一次 Git 报错、一次 VLAN 排障，当时只是一个小问题，过几周再遇到就可能又要从头摸索。
        </p>
        <p>
          所以我把博客当作外置记忆。把问题写清楚，把命令留下来，把当时的判断和误区也保存下来。它不是为了显得厉害，而是为了让未来的自己少迷路一点。
        </p>
      </section>

      <aside class="terminal-card" aria-label="写作状态终端">
        <div class="terminal-titlebar">
          <span class="window-dot dot-red" aria-hidden="true"></span>
          <span class="window-dot dot-yellow" aria-hidden="true"></span>
          <span class="window-dot dot-green" aria-hidden="true"></span>
          <span>terminal - memory sync</span>
        </div>
        <pre><code>$ mkdir -p notes/linux notes/git notes/c notes/network notes/exam
$ echo "把过程留下来" >> archive.txt
[ok] signal saved
[ok] future self can search</code></pre>
      </aside>

      <section class="bento-card route-card">
        <p class="card-kicker">TECHNICAL ROUTE</p>
        <ol class="route-list">
          {routeSteps.map(([number, title, text]) => (
            <li>
              <span>{number}</span>
              <div>
                <strong>{title}</strong>
                <p>{text}</p>
              </div>
            </li>
          ))}
        </ol>
      </section>

      <section class="bento-card category-card">
        <p class="card-kicker">ARCHIVE CATEGORIES</p>
        <div class="category-grid">
          {categoryNotes.map(([code, text]) => (
            <article>
              <span>[{code}]</span>
              <p>{text}</p>
            </article>
          ))}
        </div>
      </section>

      <section class="bento-card future-card" id="guestbook">
        <p class="card-kicker">NEXT ACTIONS</p>
        <h2>未来计划</h2>
        <ul>
          {futurePlans.map((plan) => (
            <li>
              <span class="status-light active" aria-hidden="true"></span>
              <span>{plan}</span>
            </li>
          ))}
        </ul>
      </section>
    </main>
  </section>
</BaseLayout>

<style>
  .star-page {
    position: relative;
    overflow: hidden;
    padding-bottom: 6rem;
  }

  .star-bg-layer {
    position: fixed;
    inset: 0;
    z-index: -1;
    pointer-events: none;
    background:
      linear-gradient(rgba(20, 43, 66, 0.035) 1px, transparent 1px),
      linear-gradient(90deg, rgba(20, 43, 66, 0.035) 1px, transparent 1px);
    background-size: 56px 56px;
  }

  .planet,
  .orbit-line {
    position: absolute;
    border-radius: 50%;
    opacity: 0.45;
    mix-blend-mode: multiply;
  }

  .planet-red {
    width: 160px;
    height: 160px;
    right: 9vw;
    top: 18vh;
    background: radial-gradient(circle at 32% 30%, #fff 0 8%, #ffb3a8 9% 24%, var(--theme-persimmonorange) 25% 100%);
  }

  .planet-blue {
    width: 220px;
    height: 220px;
    left: 4vw;
    top: 48vh;
    background: radial-gradient(circle at 36% 30%, #fff 0 8%, #9edfd9 9% 24%, var(--theme-mintcyan) 25% 100%);
  }

  .orbit-line {
    border: 1px dashed rgba(20, 43, 66, 0.16);
    transform: rotate(-12deg);
  }

  .orbit-one {
    width: 520px;
    height: 220px;
    right: -120px;
    top: 12vh;
  }

  .orbit-two {
    width: 620px;
    height: 260px;
    left: -180px;
    top: 44vh;
  }

  .about-title-section {
    padding-bottom: 3rem;
  }

  .about-bento {
    display: grid;
    grid-template-columns: 1.15fr 0.85fr;
    gap: 1.25rem;
    width: min(1180px, calc(100% - 8vw));
    margin: 0 auto;
  }

  .bento-card,
  .terminal-card {
    position: relative;
    overflow: hidden;
    background: rgba(250, 250, 250, 0.82);
    border: 1px solid var(--theme-line);
    box-shadow: 0 18px 48px rgba(20, 43, 66, 0.1);
    backdrop-filter: blur(14px);
  }

  .bento-card {
    padding: clamp(1.35rem, 3vw, 2.4rem);
  }

  .bento-card::after {
    content: "";
    position: absolute;
    right: -40px;
    bottom: -40px;
    width: 120px;
    height: 120px;
    border: 2px dashed rgba(178, 58, 58, 0.18);
    border-radius: 50%;
    pointer-events: none;
  }

  .intro-card,
  .route-card,
  .category-card,
  .future-card {
    grid-column: 1 / -1;
  }

  .card-kicker {
    color: var(--theme-stamp-red);
    font-size: 0.72rem;
    font-weight: 900;
    letter-spacing: 0.18em;
    margin: 0 0 1rem;
  }

  .bento-card h2 {
    color: #111;
    font-family: var(--font-serif);
    font-size: clamp(1.55rem, 4vw, 2.7rem);
    line-height: 1.25;
    margin: 0 0 1rem;
    text-wrap: balance;
  }

  .bento-card p,
  .signal-lines p,
  .route-list p,
  .category-grid p,
  .future-card li {
    color: #666;
    line-height: 1.9;
  }

  .signal-lines {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.85rem;
  }

  .signal-lines article,
  .category-grid article {
    border: 1px dashed rgba(20, 43, 66, 0.16);
    background: rgba(255, 255, 255, 0.55);
    padding: 1rem;
  }

  .signal-lines span,
  .category-grid span,
  .route-list li > span {
    color: var(--theme-blue);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 900;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .signal-lines h3 {
    color: #111;
    font-size: 1.1rem;
    margin: 0.45rem 0;
  }

  .terminal-card {
    align-self: stretch;
    background: linear-gradient(180deg, #172333, #101820);
    color: #fafafa;
  }

  .terminal-titlebar {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    min-height: 2.4rem;
    padding: 0 1rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.14);
    background: rgba(255, 255, 255, 0.08);
    color: rgba(250, 250, 250, 0.76);
    font-family: var(--font-mono);
    font-size: 0.78rem;
  }

  .terminal-card pre {
    margin: 0;
    padding: 1.35rem;
    overflow: auto;
    color: #d7fff7;
    font-family: var(--font-mono);
    font-size: 0.86rem;
    line-height: 1.75;
    white-space: pre-wrap;
  }

  .route-list {
    display: grid;
    gap: 0.75rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .route-list li {
    display: grid;
    grid-template-columns: 4rem minmax(0, 1fr);
    gap: 1rem;
    border-top: 1px dashed rgba(20, 43, 66, 0.16);
    padding-top: 1rem;
  }

  .route-list strong {
    color: #111;
    font-size: 1.05rem;
  }

  .route-list p {
    margin: 0.25rem 0 0;
  }

  .category-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.85rem;
  }

  .future-card ul {
    display: grid;
    gap: 0.85rem;
    list-style: none;
    margin: 1.25rem 0 0;
    padding: 0;
  }

  .future-card li {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
  }

  .future-card .status-light {
    margin-top: 0.55rem;
  }

  @media (max-width: 900px) {
    .about-bento,
    .signal-lines,
    .category-grid {
      grid-template-columns: 1fr;
    }

    .planet-blue,
    .planet-red,
    .orbit-line {
      opacity: 0.22;
    }
  }

  @media (max-width: 560px) {
    .about-bento {
      width: min(100% - 2rem, 1180px);
      gap: 1rem;
    }

    .route-list li {
      grid-template-columns: 1fr;
    }
  }
</style>